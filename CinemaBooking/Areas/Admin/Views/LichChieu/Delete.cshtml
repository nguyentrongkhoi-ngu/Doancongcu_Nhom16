@model CinemaBooking.Models.LichChieu

@{
    ViewData["Title"] = "Xóa lịch chiếu";
    Layout = "~/Areas/Admin/Views/Shared/_Layout.cshtml";
}

<div class="container-fluid px-4">
    <h1 class="mt-4">Xóa lịch chiếu</h1>
    <ol class="breadcrumb mb-4">
        <li class="breadcrumb-item"><a asp-controller="Home" asp-action="Index">Dashboard</a></li>
        <li class="breadcrumb-item"><a asp-action="Index">Lịch chiếu</a></li>
        <li class="breadcrumb-item active">Xóa</li>
    </ol>

    <div class="alert alert-danger shadow-sm py-4 border-start border-5 border-danger">
        <div class="d-flex align-items-center">
            <i class="fas fa-exclamation-triangle fa-3x me-4"></i>
            <div>
                <h4 class="alert-heading fw-bold mb-1">Xác nhận xóa lịch chiếu?</h4>
                <p class="mb-0">Hành động này không thể hoàn tác. Bạn có chắc chắn muốn xóa lịch chiếu này?</p>
            </div>
        </div>
    </div>

    <div class="card mb-4 shadow-sm">
        <div class="card-header bg-dark text-white py-3">
            <i class="fas fa-info-circle me-1"></i>
            Thông tin lịch chiếu #@Model.MaLichChieu
        </div>
        <div class="card-body p-4">
            <div class="row g-4 mb-4">
                <div class="col-md-3 text-center">
                    <img src="@(string.IsNullOrEmpty(Model.Phim?.UrlPoster) ? "/images/no-image.jpg" : Model.Phim.UrlPoster)" 
                         class="img-fluid rounded shadow" style="max-height: 250px;" alt="@Model.Phim?.TenPhim">
                </div>
                <div class="col-md-9">
                    <div class="row mb-3">
                        <div class="col-sm-3 fw-bold text-muted">Phim:</div>
                        <div class="col-sm-9 h5 fw-bold">@Model.Phim?.TenPhim</div>
                    </div>
                    <div class="row mb-3">
                        <div class="col-sm-3 fw-bold text-muted">Rạp / Phòng:</div>
                        <div class="col-sm-9">@Model.PhongChieu?.RapPhim?.TenRap / Phòng @Model.PhongChieu?.SoPhong</div>
                    </div>
                    <div class="row mb-3">
                        <div class="col-sm-3 fw-bold text-muted">Thời gian chiếu:</div>
                        <div class="col-sm-9 text-primary fw-bold">
                            <i class="far fa-calendar-alt me-1"></i> @Model.NgayChieu.ToString("dd/MM/yyyy") 
                            <i class="far fa-clock ms-3 me-1"></i> @Model.GioChieu.ToString(@"hh\:mm")
                        </div>
                    </div>
                    <div class="row mb-3">
                        <div class="col-sm-3 fw-bold text-muted">Giá vé:</div>
                        <div class="col-sm-9 text-success fw-bold">@Model.GiaVe.ToString("N0")đ</div>
                    </div>
                    @if (Model.NgonNguPhim != null)
                    {
                        <div class="row mb-3">
                            <div class="col-sm-3 fw-bold text-muted">Ngôn ngữ:</div>
                            <div class="col-sm-9">@Model.NgonNguPhim.NgonNgu (@Model.NgonNguPhim.PhuDe)</div>
                        </div>
                    }
                </div>
            </div>

            <hr class="my-4">

            <div class="d-flex justify-content-end gap-2">
                <a asp-action="Index" class="btn btn-outline-secondary px-4">
                    <i class="fas fa-arrow-left me-1"></i> Quay lại
                </a>
                <form asp-action="Delete" method="post">
                    <input type="hidden" asp-for="MaLichChieu" />
                    <button type="submit" class="btn btn-danger px-4 fw-bold">
                        <i class="fas fa-trash-alt me-1"></i> Xác nhận xóa
                    </button>
                </form>
            </div>
        </div>
    </div>
</div>

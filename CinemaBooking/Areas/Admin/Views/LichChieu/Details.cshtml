@model CinemaBooking.Models.LichChieu

@{
    ViewData["Title"] = "Chi tiết lịch chiếu";
    Layout = "~/Areas/Admin/Views/Shared/_Layout.cshtml";
}

<div class="container-fluid px-4">
    <h1 class="mt-4">Chi tiết lịch chiếu</h1>
    <ol class="breadcrumb mb-4">
        <li class="breadcrumb-item"><a asp-controller="Home" asp-action="Index">Dashboard</a></li>
        <li class="breadcrumb-item"><a asp-action="Index">Lịch chiếu</a></li>
        <li class="breadcrumb-item active">Chi tiết #@Model.MaLichChieu</li>
    </ol>

    <div class="card mb-4 shadow-sm border-info border-5 border-top">
        <div class="card-header bg-info text-white py-3 fw-bold">
            <i class="fas fa-info-circle me-1"></i>
            Thông tin lịch chiếu #@Model.MaLichChieu
        </div>
        <div class="card-body p-4">
            <div class="row g-4 d-flex align-items-stretch">
                <div class="col-md-3">
                    <img src="@(string.IsNullOrEmpty(Model.Phim?.UrlPoster) ? "/images/no-image.jpg" : Model.Phim.UrlPoster)" 
                         class="img-fluid rounded shadow" alt="@Model.Phim?.TenPhim">
                </div>
                <div class="col-md-9 border-start ps-4">
                    <h2 class="fw-bold text-dark mb-4">@Model.Phim?.TenPhim</h2>
                    <div class="row mb-3 pb-3 border-bottom">
                        <div class="col-sm-4 fw-bold text-muted text-uppercase small ls-1">Rạp:</div>
                        <div class="col-sm-8 fw-bold">@Model.PhongChieu?.RapPhim?.TenRap</div>
                    </div>
                    <div class="row mb-3 pb-3 border-bottom">
                        <div class="col-sm-4 fw-bold text-muted text-uppercase small ls-1">Phòng:</div>
                        <div class="col-sm-8">Phòng @Model.PhongChieu?.SoPhong</div>
                    </div>
                    <div class="row mb-3 pb-3 border-bottom">
                        <div class="col-sm-4 fw-bold text-muted text-uppercase small ls-1">Thời gian chiếu:</div>
                        <div class="col-sm-8 text-primary fw-bold">
                            <i class="far fa-calendar-alt me-1"></i> @Model.NgayChieu.ToString("dd/MM/yyyy") 
                            <i class="far fa-clock ms-3 me-1"></i> @Model.GioChieu.ToString(@"hh\:mm")
                        </div>
                    </div>
                    <div class="row mb-3 pb-3 border-bottom">
                        <div class="col-sm-4 fw-bold text-muted text-uppercase small ls-1">Giá vé:</div>
                        <div class="col-sm-8 text-success fw-bold">@Model.GiaVe.ToString("N0")đ</div>
                    </div>
                    <div class="row mb-3 pb-3 border-bottom text-dark">
                        <div class="col-sm-4 fw-bold text-muted text-uppercase small ls-1">Thể loại / Thời lượng:</div>
                        <div class="col-sm-8">@Model.Phim?.TheLoai / @Model.Phim?.ThoiLuong phút</div>
                    </div>
                    @if (Model.NgonNguPhim != null)
                    {
                        <div class="row mb-3 pb-3 border-bottom">
                            <div class="col-sm-4 fw-bold text-muted text-uppercase small ls-1">Ngôn ngữ:</div>
                            <div class="col-sm-8">@Model.NgonNguPhim.NgonNgu (@Model.NgonNguPhim.PhuDe)</div>
                        </div>
                    }
                </div>
            </div>

            <hr class="my-4">

            <div class="d-flex justify-content-end gap-2">
                <a asp-action="Index" class="btn btn-outline-secondary px-4">
                    <i class="fas fa-arrow-left me-1"></i> Quay lại
                </a>
                <a asp-action="Edit" asp-route-id="@Model.MaLichChieu" class="btn btn-warning px-4 text-dark fw-bold">
                    <i class="fas fa-edit me-1"></i> Chỉnh sửa
                </a>
            </div>
        </div>
    </div>
</div>

@model IEnumerable<CinemaBooking.Models.Combo>

@{
    ViewData["Title"] = "Quản lý Combo (F&B)";
    Layout = "~/Areas/Admin/Views/Shared/_Layout.cshtml";
}

<div class="mb-4 d-flex justify-content-between align-items-center">
    <div>
        <h3 class="fw-bold text-slate-800">Quản lý Combo (F&B)</h3>
        <p class="text-slate-500 small mb-0">Quản lý danh sách đồ ăn, nước uống và các gói combo khuyến mãi.</p>
    </div>
    <a asp-action="Create" class="btn btn-primary d-flex align-items-center gap-2">
        <i class="fas fa-plus"></i>
        Thêm Combo mới
    </a>
</div>

<div class="card border-0 shadow-sm rounded-4 mb-4">
    <div class="card-body p-3">
        <div class="row align-items-center g-3">
            <div class="col-md-auto">
                <div class="nav nav-pills bg-light p-1 rounded-3 border">
                    <button class="nav-link active px-3 filter-btn" data-filter="all">Tất cả</button>
                    <button class="nav-link px-3 filter-btn" data-filter="Combo">Combo</button>
                    <button class="nav-link px-3 filter-btn" data-filter="Bắp">Bắp rang</button>
                    <button class="nav-link px-3 filter-btn" data-filter="Nước">Nước uống</button>
                </div>
            </div>
            <div class="col-md">
                <div class="input-group border rounded-3 shadow-sm">
                    <span class="input-group-text bg-white border-0"><i class="fas fa-search text-muted"></i></span>
                    <input type="text" id="adminComboSearch" class="form-control border-0" placeholder="Tìm kiếm tên combo hoặc sản phẩm...">
                </div>
            </div>
        </div>
    </div>
</div>

<div class="card border-0 shadow-sm rounded-4">
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead class="bg-slate-50 text-slate-600">
                    <tr>
                        <th class="ps-4 py-3 text-uppercase small fw-bold">Combo / Món ăn</th>
                        <th class="py-3 text-uppercase small fw-bold">Loại</th>
                        <th class="py-3 text-uppercase small fw-bold text-center">Giá</th>
                        <th class="py-3 text-uppercase small fw-bold text-center">Tồn kho</th>
                        <th class="py-3 text-uppercase small fw-bold text-center">Đã bán</th>
                        <th class="py-3 text-uppercase small fw-bold text-center">Trạng thái</th>
                        <th class="pe-4 py-3 text-uppercase small fw-bold text-end">Thao tác</th>
                    </tr>
                </thead>
                <tbody class="border-top-0">
                    @{
                        var soldCounts = ViewBag.SoldCounts as Dictionary<int, int> ?? new Dictionary<int, int>();
                    }
                    @foreach (var item in Model)
                    {
                        var totalSold = soldCounts.ContainsKey(item.MaCombo) ? soldCounts[item.MaCombo] : 0;
                        <tr class="combo-row" data-category="@item.Loai" data-search="@item.TenCombo.ToLower() @item.MaCombo">
                            <td class="ps-4 py-3">
                                <div class="d-flex align-items-center gap-3">
                                    <div class="position-relative">
                                        <img src="@item.HinhAnh" alt="@item.TenCombo" 
                                             class="rounded-3 shadow-sm border"
                                             style="width: 70px; height: 70px; object-fit: cover;">
                                        <span class="position-absolute top-0 start-0 translate-middle badge rounded-pill bg-dark border border-light small" style="font-size: 0.6rem; z-index: 5;">
                                            #@item.UuTien
                                        </span>
                                        @if (!string.IsNullOrEmpty(item.Nhan)) {
                                            <span class="position-absolute top-100 start-50 translate-middle badge rounded-pill bg-danger border border-white small py-1 px-2" 
                                                  style="font-size: 0.55rem; white-space: nowrap; font-weight: 800; transform: translate(-50%, -100%) !important;">
                                                @item.Nhan.ToUpper()
                                            </span>
                                        }
                                    </div>
                                    <div>
                                        <div class="d-flex align-items-center gap-2">
                                            <div class="fw-bold text-slate-800">@item.TenCombo</div>
                                            @if (!string.IsNullOrEmpty(item.KichThuoc)) {
                                                <span class="badge bg-secondary-subtle text-secondary border border-secondary-subtle px-2 py-1" style="font-size: 0.65rem;">
                                                    <i class="fas fa-arrows-alt me-1"></i>SIZE: @item.KichThuoc.ToUpper()
                                                </span>
                                            }
                                        </div>
                                        <div class="text-slate-400 small" title="@item.MoTa">
                                            @(item.MoTa?.Length > 40 ? item.MoTa.Substring(0, 40) + "..." : item.MoTa)
                                        </div>
                                    </div>
                                </div>
                            </td>
                            <td class="py-3">
                                @if (item.Loai == "Combo") {
                                    <span class="badge bg-primary-subtle text-primary border border-primary-subtle rounded-pill">Combo</span>
                                } else if (item.Loai == "Bắp") {
                                    <span class="badge bg-warning-subtle text-warning border border-warning-subtle rounded-pill">Bắp</span>
                                } else if (item.Loai == "Nước") {
                                    <span class="badge bg-info-subtle text-info border border-info-subtle rounded-pill">Nước</span>
                                } else {
                                    <span class="badge bg-secondary-subtle text-secondary border border-secondary-subtle rounded-pill">@item.Loai</span>
                                }
                            </td>
                            <td class="py-3 text-center">
                                <div class="fw-bold text-slate-700">@string.Format("{0:N0}đ", item.Gia)</div>
                            </td>
                            <td class="py-3 text-center">
                                @if (item.SoLuongTon <= 10) {
                                    <div class="badge bg-danger-subtle text-danger border border-danger-subtle rounded-pill px-3">
                                        <i class="fas fa-exclamation-triangle me-1"></i> @item.SoLuongTon
                                    </div>
                                } else {
                                    <div class="text-slate-600 fw-medium">@item.SoLuongTon</div>
                                }
                            </td>
                            <td class="py-3 text-center">
                                <div class="text-slate-500 font-monospace">@totalSold.ToString("N0")</div>
                            </td>
                            <td class="py-3 text-center">
                                <div class="form-check form-switch d-flex justify-content-center">
                                    <input class="form-check-input status-toggle" type="checkbox" 
                                           data-id="@item.MaCombo" @(item.TrangThai ? "checked" : "")
                                           style="cursor: pointer; width: 2.5em; height: 1.25em;">
                                </div>
                            </td>
                            <td class="pe-4 py-3 text-end">
                                <div class="d-flex justify-content-end gap-2">
                                    <a asp-action="Edit" asp-route-id="@item.MaCombo" 
                                       class="btn btn-light btn-sm border shadow-sm"
                                       title="Chỉnh sửa">
                                        <i class="fas fa-pen text-primary small"></i>
                                    </a>
                                    <button type="button" 
                                            class="btn btn-light btn-sm border shadow-sm"
                                            title="Xóa"
                                            onclick="confirmDelete(@item.MaCombo, '@item.TenCombo')">
                                        <i class="fas fa-trash-alt text-danger small"></i>
                                    </button>
                                </div>
                            </td>
                        </tr>
                    }
                    @if (!Model.Any())
                    {
                        <tr>
                            <td colspan="4" class="text-center py-5 text-slate-400">
                                <i class="fas fa-box-open fa-3x mb-3 d-block opacity-25"></i>
                                Chưa có combo nào trong danh sách.
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

@section Scripts {
<script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
<script>
    $(document).ready(function() {
        // --- Filtering Logic ---
        const filterBtns = $('.filter-btn');
        const comboRows = $('.combo-row');
        const searchInput = $('#adminComboSearch');

        function applyFilters() {
            const activeFilter = $('.filter-btn.active').data('filter');
            const searchText = searchInput.val().toLowerCase();

            comboRows.each(function() {
                const row = $(this);
                const category = row.data('category');
                const searchData = row.data('search');

                const matchCategory = (activeFilter === 'all' || category === activeFilter);
                const matchSearch = searchData.includes(searchText);

                if (matchCategory && matchSearch) {
                    row.show();
                } else {
                    row.hide();
                }
            });
        }

        filterBtns.on('click', function() {
            filterBtns.removeClass('active btn-primary').addClass('btn-light');
            $(this).addClass('active btn-primary').removeClass('btn-light');
            applyFilters();
        });

        searchInput.on('input', function() {
            applyFilters();
        });

        // --- Status Toggle ---
        $('.status-toggle').on('change', function() {
            var id = $(this).data('id');
            var checkbox = $(this);
            
            $.ajax({
                url: '@Url.Action("ToggleStatus", "AdminCombos")',
                type: 'POST',
                data: { id: id },
                success: function(response) {
                    if (!response.success) {
                        checkbox.prop('checked', !checkbox.is(':checked'));
                        Swal.fire('Lỗi!', 'Không thể cập nhật trạng thái.', 'error');
                    }
                },
                error: function() {
                    checkbox.prop('checked', !checkbox.is(':checked'));
                    Swal.fire('Lỗi!', 'Có lỗi xảy ra khi kết nối server.', 'error');
                }
            });
        });
    });

    function confirmDelete(id, name) {
        Swal.fire({
            title: 'Xác nhận xóa?',
            text: `Bạn có chắc chắn muốn xóa Combo "${name}" không?`,
            icon: 'warning',
            showCancelButton: true,
            confirmButtonColor: '#E50914',
            cancelButtonColor: '#6c757d',
            confirmButtonText: 'Có, xóa ngay!',
            cancelButtonText: 'Hủy'
        }).then((result) => {
            if (result.isConfirmed) {
                $.ajax({
                    url: '@Url.Action("Delete", "AdminCombos")',
                    type: 'POST',
                    data: {
                        id: id,
                        __RequestVerificationToken: $('input[name="__RequestVerificationToken"]').val()
                    },
                    success: function (response) {
                        if (response.success) {
                            Swal.fire('Đã xóa!', response.message, 'success').then(() => {
                                location.reload();
                            });
                        } else {
                            Swal.fire('Lỗi!', response.message, 'error');
                        }
                    },
                    error: function () {
                        Swal.fire('Lỗi!', 'Có lỗi xảy ra khi xử lý yêu cầu.', 'error');
                    }
                });
            }
        });
    }
</script>
}

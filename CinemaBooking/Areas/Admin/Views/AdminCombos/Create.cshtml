@model CinemaBooking.Models.Combo

@{
    ViewData["Title"] = "Thêm Combo mới";
    Layout = "~/Areas/Admin/Views/Shared/_Layout.cshtml";
}

<nav aria-label="breadcrumb" class="mb-4">
    <ol class="breadcrumb">
        <li class="breadcrumb-item"><a asp-action="Index" class="text-secondary text-decoration-none">Quản lý Combo</a></li>
        <li class="breadcrumb-item active" aria-current="page">Thêm mới</li>
    </ol>
</nav>

<div class="row">
    <div class="col-lg-8 mx-auto">
        <div class="card border-0 shadow-sm rounded-4">
            <div class="card-header bg-white py-3 border-bottom-0">
                <h5 class="card-title fw-bold text-slate-800 mb-0">🛒 Chi tiết Combo mới</h5>
            </div>
            <div class="card-body p-4">
                <form asp-action="Create" method="post" enctype="multipart/form-data">
                    <div asp-validation-summary="ModelOnly" class="text-danger small mb-3"></div>
                    
                    <div class="row g-4">
                        <div class="col-md-6">
                            <label asp-for="TenCombo" class="form-label fw-bold text-slate-700">Tên Combo/Sản phẩm</label>
                            <input asp-for="TenCombo" class="form-control shadow-sm" placeholder="Nhập tên bắp, nước hoặc combo..." required>
                            <span asp-validation-for="TenCombo" class="text-danger small"></span>
                        </div>

                        <div class="col-md-2">
                            <label asp-for="Loai" class="form-label fw-bold text-slate-700 small">Loại</label>
                            <select asp-for="Loai" class="form-select shadow-sm">
                                <option value="Combo">Combo</option>
                                <option value="Bắp">Bắp</option>
                                <option value="Nước">Nước</option>
                                <option value="Khác">Khác</option>
                            </select>
                            <span asp-validation-for="Loai" class="text-danger small"></span>
                        </div>

                        <div class="col-md-2">
                            <label asp-for="KichThuoc" class="form-label fw-bold text-slate-700 small">Kích thước</label>
                            <input asp-for="KichThuoc" class="form-control shadow-sm" list="size-suggestions" placeholder="S, M, L...">
                            <datalist id="size-suggestions">
                                <option value="S"></option>
                                <option value="M"></option>
                                <option value="L"></option>
                                <option value="XL"></option>
                                <option value="TIEU CHUAN"></option>
                            </datalist>
                            <span asp-validation-for="KichThuoc" class="text-danger small"></span>
                        </div>

                        <div class="col-md-2">
                            <label asp-for="Nhan" class="form-label fw-bold text-slate-700 small">Nhãn</label>
                            <input asp-for="Nhan" class="form-control shadow-sm" list="nhan-suggestions" placeholder="Hot, New...">
                            <datalist id="nhan-suggestions">
                                <option value="BEST SELLER"></option>
                                <option value="HOT"></option>
                                <option value="NEW"></option>
                                <option value="MỚI"></option>
                                <option value="ƯU ĐÃI"></option>
                            </datalist>
                            <span asp-validation-for="Nhan" class="text-danger small"></span>
                        </div>

                        <div class="col-md-12">
                            <label asp-for="MoTa" class="form-label fw-bold text-slate-700">Mô tả</label>
                            <textarea asp-for="MoTa" class="form-control" rows="3" placeholder="Chi tiết món ăn/nước uống có trong combo..."></textarea>
                            <span asp-validation-for="MoTa" class="text-danger small"></span>
                        </div>

                        <div class="col-md-6">
                            <label asp-for="Gia" class="form-label fw-bold text-slate-700 font-monospace">Giá bán (VNĐ)</label>
                            <div class="input-group shadow-sm border rounded-2">
                                <span class="input-group-text bg-light border-0">₫</span>
                                <input asp-for="Gia" type="number" class="form-control border-0" placeholder="0" required>
                            </div>
                            <span asp-validation-for="Gia" class="text-danger small"></span>
                        </div>

                        <div class="col-md-3">
                            <label asp-for="SoLuongTon" class="form-label fw-bold text-slate-700 font-monospace">Số lượng tồn</label>
                            <div class="input-group shadow-sm border rounded-2">
                                <span class="input-group-text bg-light border-0"><i class="fas fa-boxes"></i></span>
                                <input asp-for="SoLuongTon" type="number" class="form-control border-0" placeholder="999">
                            </div>
                            <span asp-validation-for="SoLuongTon" class="text-danger small"></span>
                        </div>

                        <div class="col-md-3">
                            <label asp-for="UuTien" class="form-label fw-bold text-slate-700 font-monospace">Thứ tự ưu tiên</label>
                            <div class="input-group shadow-sm border rounded-2">
                                <span class="input-group-text bg-light border-0"><i class="fas fa-sort-numeric-down"></i></span>
                                <input asp-for="UuTien" type="number" class="form-control border-0" placeholder="0">
                            </div>
                            <span asp-validation-for="UuTien" class="text-danger small"></span>
                        </div>

                        <div class="col-md-12">
                            <div class="form-check form-switch p-3 bg-light rounded-3 border">
                                <input class="form-check-input ms-0 me-3" type="checkbox" asp-for="TrangThai" id="statusSwitch" checked>
                                <label class="form-check-label fw-bold text-slate-800" for="statusSwitch">Kích hoạt Combo / Món ăn này</label>
                                <div class="form-text mt-1 text-slate-500">Người dùng chỉ có thể nhìn thấy và đặt hàng nếu được kích hoạt.</div>
                            </div>
                        </div>

                        <div class="col-md-12">
                            <label class="form-label fw-bold text-slate-700 mt-2">Hình ảnh Combo</label>
                            <div class="nav nav-tabs mb-3" id="imageTab" role="tablist">
                                <button class="nav-link active small" id="upload-tab" data-bs-toggle="tab" data-bs-target="#upload" type="button" role="tab">Tải ảnh lên</button>
                                <button class="nav-link small" id="url-tab" data-bs-toggle="tab" data-bs-target="#url" type="button" role="tab">Dùng link URL</button>
                            </div>
                            <div class="tab-content" id="imageTabContent">
                                <div class="tab-pane fade show active" id="upload" role="tabpanel">
                                    <input asp-for="ImageFile" type="file" class="form-control" id="file-input" accept="image/*">
                                    <div class="form-text small">Hỗ trợ JPG, PNG. Dung lượng tối đa 5MB.</div>
                                </div>
                                <div class="tab-pane fade" id="url" role="tabpanel">
                                    <input asp-for="HinhAnh" id="image-url" class="form-control" placeholder="Dán link hình ảnh combo tại đây...">
                                </div>
                            </div>
                            <span asp-validation-for="HinhAnh" class="text-danger small"></span>
                            
                            <div class="mt-3 p-2 border rounded-3 d-flex align-items-center justify-content-center bg-light" style="height: 200px;">
                                <img id="image-preview" src="/images/no-image.jpg" 
                                     alt="Preview" 
                                     class="img-fluid rounded-3 shadow-sm"
                                     style="max-height: 180px; display: block;">
                            </div>
                        </div>

                        <div class="col-12 mt-4 pt-3 border-top d-flex gap-2">
                            <button type="submit" class="btn btn-primary px-4 py-2">
                                <i class="fas fa-save me-2"></i>Lưu thông tin
                            </button>
                            <a asp-action="Index" class="btn btn-light border px-4 py-2">Hủy bỏ</a>
                        </div>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
    <script>
        $(document).ready(function() {
            // Handle URL input preview
            $('#image-url').on('input', function() {
                var url = $(this).val();
                if (url) {
                    $('#image-preview').attr('src', url).on('error', function() {
                        $(this).attr('src', '/images/no-image.jpg');
                    });
                } else {
                    $('#image-preview').attr('src', '/images/no-image.jpg');
                }
            });

            // Handle File input preview
            $('#file-input').on('change', function() {
                const file = this.files[0];
                if (file) {
                    const reader = new FileReader();
                    reader.onload = function(e) {
                        $('#image-preview').attr('src', e.target.result);
                    }
                    reader.readAsDataURL(file);
                }
            });

            // Clear other input when switching tabs (Optional but cleaner)
            $('button[data-bs-toggle="tab"]').on('shown.bs.tab', function (e) {
                const target = $(e.target).attr('data-bs-target');
                if (target === '#upload') {
                    $('#image-url').val('');
                } else {
                    $('#file-input').val('');
                }
            });
        });
    </script>
}

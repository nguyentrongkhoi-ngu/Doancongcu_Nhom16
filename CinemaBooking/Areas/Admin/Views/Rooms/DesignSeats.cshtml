@model CinemaBooking.Models.PhongChieu
@{
    ViewData["Title"] = "Thiết kế sơ đồ ghế - Phòng " + Model.SoPhong;
    Layout = "_AdminLayout";
}

<style>
    .seat-container {
        display: grid;
        gap: 10px;
        padding: 40px;
        background: #1a1a1a;
        border-radius: 12px;
        overflow-x: auto;
        box-shadow: inset 0 0 20px rgba(0,0,0,0.5);
        justify-content: center;
        perspective: 1000px;
    }

    .seat-cell {
        width: 38px;
        height: 38px;
        border-radius: 6px;
        border: 2px solid rgba(255,255,255,0.1);
        display: flex;
        align-items: center;
        justify-content: center;
        cursor: pointer;
        font-size: 10px;
        color: white;
        transition: all 0.2s cubic-bezier(0.4, 0, 0.2, 1);
        user-select: none;
        position: relative;
    }

    .seat-cell:hover {
        transform: scale(1.1) translateZ(10px);
        z-index: 10;
        box-shadow: 0 5px 15px rgba(0,0,0,0.3);
    }

    .seat-normal { background-color: #4b5563; }
    .seat-vip { background-color: #fbbf24; color: #000; border-color: #f59e0b; }
    .seat-sweetbox { background-color: #ec4899; }
    .seat-empty { background-color: transparent; border: 1px dashed rgba(255,255,255,0.1); color: rgba(255,255,255,0.2); }

    .seat-cell.selected {
        outline: 3px solid #3b82f6;
        outline-offset: 2px;
        z-index: 20;
    }

    .screen {
        width: 80%;
        height: 8px;
        background: linear-gradient(to bottom, #fff, #3b82f6);
        margin: 0 auto 50px auto;
        border-radius: 5px;
        box-shadow: 0 10px 20px rgba(59, 130, 246, 0.4);
        position: relative;
    }

    .screen::after {
        content: "MÀN HÌNH CHÍNH";
        position: absolute;
        top: 15px;
        left: 50%;
        transform: translateX(-50%);
        font-size: 12px;
        color: #3b82f6;
        letter-spacing: 5px;
        font-weight: bold;
    }

    .legend-item {
        display: flex;
        align-items: center;
        gap: 8px;
        margin-bottom: 8px;
        font-size: 14px;
        cursor: pointer;
        padding: 5px 10px;
        border-radius: 6px;
        transition: background 0.2s;
    }

    .legend-item:hover { background: #f3f4f6; }
    .legend-item.active { background: #e0e7ff; color: #3730a3; font-weight: bold; }

    .legend-box {
        width: 18px;
        height: 18px;
        border-radius: 4px;
    }

    #toolbox {
        position: sticky;
        top: 20px;
    }
</style>

<div class="container-fluid px-4">
    <div class="d-flex justify-content-between align-items-end mt-4 mb-4">
        <div>
            <h1 class="mb-0">Thiết kế sơ đồ ghế</h1>
            <p class="text-muted">Phòng: @Model.SoPhong | Rạp: @Model.RapPhim.TenRap</p>
        </div>
        <div class="d-flex gap-2">
            <button id="btnSave" class="btn btn-primary rounded-pill px-4 shadow">
                <i class="fas fa-save me-1"></i> Lưu sơ đồ
            </button>
            <a asp-action="Index" asp-route-cinemaId="@Model.MaRap" class="btn btn-light rounded-pill px-4">Quay lại</a>
        </div>
    </div>

    <div class="row">
        <div class="col-lg-9">
            <div class="card border-0 shadow-sm overflow-hidden mb-4">
                <div class="card-body bg-dark text-center py-5">
                    <div class="screen"></div>
                    <div id="seatMatrix" class="seat-container" 
                         style="grid-template-columns: repeat(@Model.SoCot, auto)">
                        @for (int r = 0; r < Model.SoHang; r++)
                        {
                            char rowLetter = (char)('A' + r);
                            for (int c = 0; c < Model.SoCot; c++)
                            {
                                int colNum = c + 1;
                                string seatName = $"{rowLetter}{colNum}";
                                var seat = Model.Ghes?.FirstOrDefault(g => g.Hang == r && g.Cot == c);
                                string seatType = seat?.LoaiGhe ?? "Thường";
                                string cssClass = "seat-normal";
                                if (seatType == "VIP") cssClass = "seat-vip";
                                else if (seatType == "Sweetbox") cssClass = "seat-sweetbox";
                                else if (seat == null && Model.Ghes != null && Model.Ghes.Any()) cssClass = "seat-empty"; 
                                
                                <div class="seat-cell @cssClass" 
                                     data-row="@r" 
                                     data-col="@c" 
                                     data-name="@seatName"
                                     data-type="@(cssClass == "seat-empty" ? "Empty" : seatType)">
                                    @seatName
                                </div>
                            }
                        }
                    </div>
                </div>
                <div class="card-footer bg-white border-0 py-3 text-center">
                    <span id="capacityLabel" class="badge bg-primary rounded-pill px-3 py-2">Sức chứa: 0 ghế</span>
                </div>
            </div>
        </div>

        <div class="col-lg-3">
            <div id="toolbox" class="card border-0 shadow-sm sticky-top" style="top: 20px;">
                <div class="card-header bg-white py-3">
                    <strong><i class="fas fa-tools me-1"></i> Công cụ</strong>
                </div>
                <div class="card-body">
                    <p class="small text-muted mb-3">Chọn loại ghế bên dưới rồi click vào lưới để thay đổi.</p>
                    
                    <div id="typeSelector">
                        <div class="legend-item active" data-tool="Thường">
                            <div class="legend-box seat-normal"></div>
                            <span>Ghế Thường</span>
                        </div>
                        <div class="legend-item" data-tool="VIP">
                            <div class="legend-box seat-vip"></div>
                            <span>Ghế VIP</span>
                        </div>
                        <div class="legend-item" data-tool="Sweetbox">
                            <div class="legend-box seat-sweetbox"></div>
                            <span>Ghế Sweetbox</span>
                        </div>
                        <hr />
                        <div class="legend-item" data-tool="Empty">
                            <div class="legend-box seat-empty"></div>
                            <span>Xóa (Ô trống / Lối đi)</span>
                        </div>
                    </div>

                    <div class="mt-4">
                        <button id="btnBulk" class="btn btn-outline-primary btn-sm w-100 rounded-pill mb-2">
                             Đặt tât cả là Thường
                        </button>
                        <button id="btnClear" class="btn btn-outline-danger btn-sm w-100 rounded-pill">
                             Xóa hết ô
                        </button>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <script>
        let currentTool = "Thường";
        const roomId = @Model.MaPhong;
        const rows = @Model.SoHang;
        const cols = @Model.SoCot;

        $(document).ready(function() {
            updateCapacity();

            // Chon cong cu
            $('.legend-item').click(function() {
                $('.legend-item').removeClass('active');
                $(this).addClass('active');
                currentTool = $(this).data('tool');
            });

            // Click vao ghe
            $('.seat-cell').click(function() {
                const cell = $(this);
                const prevType = cell.data('type');
                
                // Update class
                cell.removeClass('seat-normal seat-vip seat-sweetbox seat-empty');
                cell.data('type', currentTool);

                if (currentTool === "Thường") cell.addClass('seat-normal');
                else if (currentTool === "VIP") cell.addClass('seat-vip');
                else if (currentTool === "Sweetbox") cell.addClass('seat-sweetbox');
                else if (currentTool === "Empty") cell.addClass('seat-empty');

                updateCapacity();
            });

            // Giao dien keo tha (chuot trai)
            let isDragging = false;
            $('.seat-cell').mousedown(function() { isDragging = true; });
            $(document).mouseup(function() { isDragging = false; });
            $('.seat-cell').mouseenter(function() {
                if (isDragging) $(this).click();
            });

            // Nut luu
            $('#btnSave').click(function() {
                const layout = {
                    roomId: roomId,
                    rows: rows,
                    cols: cols,
                    seats: []
                };

                $('.seat-cell').each(function() {
                    const cell = $(this);
                    layout.seats.push({
                        seatName: cell.data('name'),
                        seatType: cell.data('type'),
                        row: cell.data('row'),
                        col: cell.data('col')
                    });
                });

                $(this).attr('disabled', true).html('<i class="fas fa-spinner fa-spin me-1"></i> Đang lưu...');

                $.ajax({
                    url: '/Admin/Rooms/SaveLayout',
                    type: 'POST',
                    contentType: 'application/json',
                    data: JSON.stringify(layout),
                    success: function(res) {
                        if (res.success) {
                            Swal.fire('Thành công', res.message, 'success').then(() => {
                                window.location.href = '@Url.Action("Index", new { cinemaId = Model.MaRap })';
                            });
                        } else {
                            Swal.fire('Lỗi', res.message, 'error');
                        }
                    },
                    error: function() {
                        Swal.fire('Lỗi', 'Lỗi kết nối máy chủ', 'error');
                    },
                    complete: function() {
                        $('#btnSave').attr('disabled', false).html('<i class="fas fa-save me-1"></i> Lưu sơ đồ');
                    }
                });
            });

            $('#btnBulk').click(function() {
                $('.seat-cell').each(function() {
                    $(this).removeClass('seat-vip seat-sweetbox seat-empty').addClass('seat-normal').data('type', 'Thường');
                });
                updateCapacity();
            });

            $('#btnClear').click(function() {
                $('.seat-cell').each(function() {
                    $(this).removeClass('seat-normal seat-vip seat-sweetbox').addClass('seat-empty').data('type', 'Empty');
                });
                updateCapacity();
            });
        });

        function updateCapacity() {
            const count = $('.seat-cell').filter(function() {
                return $(this).data('type') !== 'Empty';
            }).length;
            $('#capacityLabel').text('Sức chứa: ' + count + ' ghế');
        }
    </script>
}

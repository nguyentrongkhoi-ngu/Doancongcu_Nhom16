@model CinemaBooking.Models.DatVe

@{
    ViewData["Title"] = "Thanh toán thành công | CineZore";
    var posterUrl = string.IsNullOrEmpty(Model.LichChieu.Phim.UrlPoster) ? "/images/no-image.jpg" : Model.LichChieu.Phim.UrlPoster;
    var showtimeStr = $"{Model.LichChieu.GioChieu.Hours:D2}:{Model.LichChieu.GioChieu.Minutes:D2}";
    var selectedSeats = Model.DatVeGhes != null && Model.DatVeGhes.Any() 
                        ? string.Join(", ", Model.DatVeGhes.Select(g => g.Ghe.SoGhe)) 
                        : "N/A";
}

<script>document.body.classList.add('immersive-page');</script>

@section Styles {
<style>
    /* ===== DESIGN TOKENS ===== */
    :root {
        --cz-bg:           #0a0a0f;
        --cz-surface:      #111117;
        --cz-border:       rgba(255,255,255,0.08);
        --cz-accent:       #E50914;
        --cz-success:      #10b981;
        --cz-text:         #ffffff;
        --cz-text-sub:     rgba(255,255,255,0.70);
        --cz-text-muted:   rgba(255,255,255,0.40);
        --cz-ease:         cubic-bezier(0.4, 0, 0.2, 1);
        --cz-surface-2:    #18181f;
    }

    /* ===== PROGRESS STEPPER ===== */
    .cz-stepper {
        display: flex;
        justify-content: center;
        align-items: center;
        margin-bottom: 36px;
        gap: 0;
    }

    .cz-step {
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: 12px;
        position: relative;
        flex: 1;
        max-width: 140px;
    }

    .cz-step__icon {
        width: 32px; height: 32px;
        border-radius: 50%;
        background: var(--cz-surface-2);
        border: 2px solid var(--cz-border);
        display: flex; align-items: center; justify-content: center;
        font-size: 0.85rem;
        font-weight: 800;
        color: var(--cz-text-muted);
        z-index: 2;
        transition: all 0.4s var(--cz-ease);
    }

    .cz-step__label {
        font-size: 0.62rem;
        font-weight: 800;
        text-transform: uppercase;
        letter-spacing: 1.2px;
        color: var(--cz-text-muted);
        transition: all 0.4s var(--cz-ease);
    }

    .cz-step__line {
        position: absolute;
        top: 16px;
        left: calc(50% + 22px);
        width: calc(100% - 44px);
        height: 2px;
        background: var(--cz-border);
        z-index: 1;
    }

    .cz-step.is-active .cz-step__icon {
        background: var(--cz-accent);
        border-color: var(--cz-accent);
        color: #fff;
        box-shadow: 0 0 20px rgba(229,9,20,0.4);
    }
    .cz-step.is-active .cz-step__label { color: var(--cz-text); }

    .cz-step.is-completed .cz-step__icon {
        background: var(--cz-success);
        border-color: var(--cz-success);
        color: #fff;
    }
    .cz-step.is-completed .cz-step__label { color: var(--cz-text-sub); }
    .cz-step.is-completed .cz-step__line { background: var(--cz-success); }
    
    @@media (max-width: 576px) {
        .cz-stepper { gap: 10px; }
        .cz-step__line { display: none; }
    }

    body {
        background: var(--cz-bg) !important;
        color: var(--cz-text) !important;
        font-family: 'Outfit', 'Inter', sans-serif !important;
    }

    .tt-ambient {
        position: fixed;
        inset: 0; z-index: -1;
        background-size: cover;
        background-position: center 25%;
        filter: blur(80px) brightness(0.18) saturate(1.2);
        transform: scale(1.1);
    }

    .tt-page {
        padding-top: 160px;
        padding-bottom: 40px;
        max-width: 780px;
        min-height: 85vh;
        display: flex;
        flex-direction: column;
        justify-content: center;
    }

    /* Success Header */
    .tt-success-header {
        text-align: center;
        margin-bottom: 40px;
        animation: fadeSlideDown 0.6s var(--cz-ease) both;
    }

    .tt-success-icon {
        width: 64px; height: 64px;
        border-radius: 50%;
        background: rgba(16, 185, 129, 0.1);
        color: var(--cz-success);
        font-size: 2rem;
        display: flex; align-items: center; justify-content: center;
        margin: 0 auto 16px;
        position: relative;
    }

    .tt-success-icon::after {
        content: '';
        position: absolute;
        inset: -10px;
        border-radius: 50%;
        border: 2px dashed rgba(16, 185, 129, 0.3);
        animation: rotate 10s linear infinite;
    }

    .tt-success-title {
        font-size: 1.8rem;
        font-weight: 900;
        color: var(--cz-text);
        letter-spacing: -0.5px;
        margin-bottom: 10px;
    }

    .tt-success-desc {
        color: var(--cz-text-sub);
        font-size: 0.95rem;
    }

    /* Digital Ticket */
    .tt-digital-ticket {
        background: var(--cz-surface);
        border: 1px solid var(--cz-border);
        border-radius: 24px;
        overflow: hidden;
        position: relative;
        box-shadow: 0 20px 40px rgba(0,0,0,0.4);
        animation: fadeSlideUp 0.6s var(--cz-ease) 0.1s both;
    }

    /* Ticket Header - Poster & Movie */
    .tt-ticket-header {
        position: relative;
        padding: 30px 30px 20px;
        display: flex;
        gap: 20px;
        background: linear-gradient(to bottom, rgba(255,255,255,0.03), transparent);
    }

    .tt-ticket-header::after {
        content: '';
        position: absolute;
        bottom: 0; left: 40px; right: 40px;
        height: 1px;
        background: var(--cz-border);
        border-bottom: 1px dashed rgba(0,0,0,0.5); /* Punch hole effect base */
    }

    /* Side cutouts (ticket punch holes) */
    .tt-ticket-cutout {
        position: absolute;
        bottom: -15px; /* Half of height */
        width: 30px; height: 30px;
        background: var(--cz-bg);
        border-radius: 50%;
        border: 1px solid var(--cz-border);
        box-shadow: inset 0 3px 5px rgba(0,0,0,0.8);
        z-index: 2;
    }

    .tt-ticket-cutout--left {
        left: -16px;
        border-right-color: transparent;
        border-top-color: transparent;
        border-bottom-color: transparent;
    }
    
    .tt-ticket-cutout--right {
        right: -16px;
        border-left-color: transparent;
        border-top-color: transparent;
        border-bottom-color: transparent;
    }


    .tt-th-poster {
        width: 100px;
        height: 145px;
        border-radius: 8px;
        object-fit: cover;
        box-shadow: 0 8px 24px rgba(0,0,0,0.6);
        flex-shrink: 0;
    }

    .tt-th-info {
        flex: 1;
        display: flex;
        flex-direction: column;
        justify-content: center;
    }

    .tt-th-badge {
        align-self: flex-start;
        background: rgba(229,9,20,0.15);
        color: var(--cz-accent);
        padding: 4px 12px;
        border-radius: 6px;
        font-size: 0.75rem;
        font-weight: 800;
        letter-spacing: 1px;
        text-transform: uppercase;
        margin-bottom: 12px;
        border: 1px solid rgba(229,9,20,0.3);
    }

    .tt-th-title {
        font-size: 1.6rem;
        font-weight: 950;
        line-height: 1.1;
        letter-spacing: -0.5px;
        margin-bottom: 6px;
    }

    .tt-th-theater {
        font-size: 0.9rem;
        color: var(--cz-text-sub);
    }

    /* Ticket Body - Grid Details */
    .tt-ticket-body {
        padding: 30px;
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        gap: 20px;
    }

    .tt-detail-box {
        display: flex;
        flex-direction: column;
        gap: 6px;
    }

    .tt-detail-label {
        font-size: 0.75rem;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 1.5px;
        color: var(--cz-text-muted);
    }

    .tt-detail-value {
        font-size: 1.25rem;
        font-weight: 800;
        color: var(--cz-text);
        line-height: 1.2;
    }

    .tt-detail-value--acc {
        color: var(--cz-accent);
    }

    /* Ticket Footer - Barcode & Actions */
    .tt-ticket-footer {
        padding: 20px 30px 30px;
        background: rgba(0,0,0,0.2);
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 20px;
    }

    .tt-barcode {
        display: flex;
        flex-direction: column;
        align-items: flex-start;
        gap: 8px;
    }
    
    .tt-barcode-bars {
        height: 40px;
        width: 170px;
        background: 
            repeating-linear-gradient(
                90deg,
                rgba(255,255,255,0.7) 0,
                rgba(255,255,255,0.7) 3px,
                transparent 3px,
                transparent 6px,
                rgba(255,255,255,0.7) 6px,
                rgba(255,255,255,0.7) 8px,
                transparent 8px,
                transparent 14px,
                rgba(255,255,255,0.7) 14px,
                rgba(255,255,255,0.7) 17px
            );
        border-radius: 2px;
        opacity: 0.8;
    }

    .tt-barcode-text {
        font-family: monospace;
        font-size: 0.9rem;
        color: var(--cz-text-muted);
        letter-spacing: 4px;
    }

    .tt-actions {
        display: flex;
        gap: 12px;
    }

    .tt-btn {
        padding: 12px 24px;
        border-radius: 8px;
        font-size: 0.88rem;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 1px;
        text-decoration: none !important;
        transition: all 0.25s;
        display: inline-flex;
        align-items: center;
        gap: 8px;
    }

    .tt-btn--primary {
        background: var(--cz-accent);
        color: #fff !important;
        border: 1px solid var(--cz-accent);
    }
    .tt-btn--primary:hover {
        background: #c40812;
        transform: translateY(-2px);
        box-shadow: 0 4px 12px rgba(229,9,20,0.3);
    }

    .tt-btn--secondary {
        background: rgba(255,255,255,0.05);
        border: 1px solid var(--cz-border);
        color: var(--cz-text-sub) !important;
    }
    .tt-btn--secondary:hover {
        background: rgba(255,255,255,0.1);
        border-color: var(--cz-border-hover);
        color: var(--cz-text) !important;
    }

    /* Animations */
    @@keyframes fadeSlideDown {
        from { opacity: 0; transform: translateY(-20px); }
        to { opacity: 1; transform: translateY(0); }
    }

    @@keyframes fadeSlideUp {
        from { opacity: 0; transform: translateY(40px); }
        to { opacity: 1; transform: translateY(0); }
    }

    @@keyframes rotate {
        from { transform: rotate(0deg); }
        to { transform: rotate(360deg); }
    }

    @@media (max-width: 768px) {
        .tt-ticket-header { flex-direction: column; align-items: center; text-align: center; }
        .tt-th-badge { align-self: center; }
        .tt-ticket-body { grid-template-columns: 1fr 1fr; gap: 20px; }
        .tt-ticket-footer { flex-direction: column; align-items: center; text-align: center; }
    }
</style>
}

<div class="tt-ambient" style="background-image: url('@posterUrl');"></div>

<div class="container tt-page">
    
    <!-- Progress Stepper -->
    <div class="cz-stepper">
        <div class="cz-step is-completed">
            <div class="cz-step__icon"><i class="fas fa-check"></i></div>
            <div class="cz-step__label">Chọn ghế</div>
            <div class="cz-step__line"></div>
        </div>
        <div class="cz-step is-completed">
            <div class="cz-step__icon"><i class="fas fa-check"></i></div>
            <div class="cz-step__label">Thanh toán</div>
            <div class="cz-step__line"></div>
        </div>
        <div class="cz-step is-active">
            <div class="cz-step__icon">3</div>
            <div class="cz-step__label">Hoàn tất</div>
        </div>
    </div>
    
    <!-- Success Message -->
    <div class="tt-success-header">
        <div class="tt-success-icon"><i class="fas fa-check"></i></div>
        <h1 class="tt-success-title">Đặt vé Thành công!</h1>
        <p class="tt-success-desc">Vé điện tử của bạn đã sẵn sàng. Vui lòng đưa vé này cho nhân viên khi đến rạp.</p>
    </div>

    <!-- DIGITAL TICKET -->
    <div class="tt-digital-ticket">
        
        <!-- Header Section -->
        <div class="tt-ticket-header">
            <div class="tt-ticket-cutout tt-ticket-cutout--left"></div>
            <div class="tt-ticket-cutout tt-ticket-cutout--right"></div>
            
            <img src="@posterUrl" alt="Poster" class="tt-th-poster">
            <div class="tt-th-info">
                <span class="tt-th-badge">Vé điện tử</span>
                <h2 class="tt-th-title">@Model.LichChieu.Phim.TenPhim</h2>
                <div class="tt-th-theater">@Model.LichChieu.PhongChieu.RapPhim.TenRap</div>
            </div>
        </div>

        <!-- Body Section -->
        <div class="tt-ticket-body">
            <div class="tt-detail-box">
                <span class="tt-detail-label">Ngày xem</span>
                <span class="tt-detail-value">@Model.LichChieu.NgayChieu.ToString("dd/MM/yyyy")</span>
            </div>
            <div class="tt-detail-box">
                <span class="tt-detail-label">Giờ chiếu</span>
                <span class="tt-detail-value">@showtimeStr</span>
            </div>
            <div class="tt-detail-box">
                <span class="tt-detail-label">Phòng</span>
                <span class="tt-detail-value tt-detail-value--acc">Phòng @Model.LichChieu.PhongChieu.SoPhong</span>
            </div>
            
            <div class="tt-detail-box" style="grid-column: span 2;">
                <span class="tt-detail-label">Ghế</span>
                <span class="tt-detail-value" style="font-size: 1.1rem;">@selectedSeats</span>
            </div>
            <div class="tt-detail-box">
                <span class="tt-detail-label">Mã vé</span>
                <span class="tt-detail-value" style="font-size: 1.1rem;">#@Model.MaDatVe</span>
            </div>
        </div>

        <!-- Footer Section -->
        <div class="tt-ticket-footer">
            <div class="tt-barcode">
                <div class="tt-barcode-bars"></div>
                <div class="tt-barcode-text">CINE-@Model.MaDatVe.ToString("D6")-2026</div>
            </div>
            <div class="tt-actions">
                <a href="@Url.Action("Print", "DatVe", new { maDatVe = Model.MaDatVe })" class="tt-btn tt-btn--secondary" target="_blank">
                    <i class="fas fa-print"></i> In vé
                </a>
                <a href="@Url.Action("Index", "Home")" class="tt-btn tt-btn--primary">
                    Về Trang Chủ
                </a>
            </div>
        </div>

    </div>
</div>
@model CinemaBooking.Models.DatVe

@{
    ViewData["Title"] = "Thanh toán – " + Model.LichChieu.Phim.TenPhim;
    var posterUrl = string.IsNullOrEmpty(Model.LichChieu.Phim.UrlPoster) ? "/images/no-image.jpg" : Model.LichChieu.Phim.UrlPoster;
    var showtimeStr = $"{Model.LichChieu.GioChieu.Hours:D2}:{Model.LichChieu.GioChieu.Minutes:D2}";
    var selectedSeats = Model.DatVeGhes != null && Model.DatVeGhes.Any() 
                        ? string.Join(", ", Model.DatVeGhes.Select(g => g.Ghe.SoGhe)) 
                        : "N/A";
    
    // Calculations for Breakdown
    var ticketCount = Model.DatVeGhes?.Count ?? 0;
    var seatTotal = Model.DatVeGhes?.Sum(g => {
        // Simple logic mirroring controller (should ideally come from DB if per-seat price is stored)
        var soGhe = g.Ghe.SoGhe;
        var row = soGhe[0];
        var col = int.Parse(soGhe.Substring(1));
        decimal gia = Model.LichChieu.GiaVe;
        if (row >= 'J') gia = Model.LichChieu.GiaVe * 1.2m;
        if (row == 'P' && col <= 4) gia = Model.LichChieu.GiaVe * 1.5m;
        return gia;
    }) ?? 0;
    
    var comboTotal = Model.DatVeCombos?.Sum(c => c.Combo.Gia * c.SoLuong) ?? 0;
    var subtotal = seatTotal + comboTotal;
    var discount = subtotal * (Model.KhuyenMai?.PhanTramGiam / 100m ?? 0); 
    if (Model.MaKhuyenMai.HasValue && discount == 0) discount = subtotal - Model.TongTien; // Fallback

}

<script>document.body.classList.add('immersive-page');</script>

@section Styles {
<style>
    /* ===== DESIGN TOKENS ===== */
    :root {
        --cz-bg:           #0a0a0f;
        --cz-surface:      #111117;
        --cz-surface-2:    #18181f;
        --cz-border:       rgba(255,255,255,0.08);
        --cz-border-hover: rgba(255,255,255,0.20);
        --cz-accent:       #E50914;
        --cz-accent-glow:  rgba(229,9,20,0.5);
        --cz-accent-dim:   rgba(229,9,20,0.12);
        --cz-success:      #10b981;
        --cz-warning:      #f59e0b;
        --cz-text:         #ffffff;
        --cz-text-sub:     rgba(255,255,255,0.75);
        --cz-text-muted:   rgba(255,255,255,0.45);
        --cz-ease:         cubic-bezier(0.4, 0, 0.2, 1);
        --cz-radius:       24px;
    }

    /* ===== HEADER BAR ===== */
    .tt-header-bar {
        position: relative;
        display: flex;
        justify-content: center;
        align-items: center;
        margin-bottom: 10px;
        min-height: 30px;
    }

    /* ===== PROGRESS STEPPER ===== */

    body {
        background: var(--cz-bg) !important;
        color: var(--cz-text) !important;
        font-family: 'Outfit', 'Inter', sans-serif !important;
        line-height: 1.6;
    }

    /* Ambient background */
    .tt-ambient {
        position: fixed;
        inset: 0; z-index: -1;
        background-size: cover;
        background-position: center 25%;
        filter: blur(100px) brightness(0.18) saturate(1.4);
        transform: scale(1.1);
    }

    .tt-page {
        padding-bottom: 80px !important;
        max-width: 1000px;
        display: flex;
        flex-direction: column;
    }

    /* ===== TIMER BAR ===== */
    .tt-timer-bar {
        position: absolute;
        right: 0;
        top: 50%;
        transform: translateY(-50%);
        background: rgba(255,255,255,0.03);
        border: 1px solid var(--cz-border);
        border-radius: 50px;
        padding: 6px 16px;
        display: inline-flex;
        align-items: center;
        gap: 8px;
        font-size: 0.82rem;
        backdrop-filter: blur(10px);
        transition: all 0.5s var(--cz-ease);
    }
    .tt-timer-bar.warning { border-color: var(--cz-warning); color: var(--cz-warning); background: rgba(245,158,11,0.05); }
    .tt-timer-bar.danger  { border-color: var(--cz-accent); color: var(--cz-accent); background: rgba(229,9,20,0.08); animation: pulse 1s infinite; }

    @@keyframes pulse {
        0%, 100% { opacity: 1; }
        50% { opacity: 0.7; }
    }

    .tt-timer-clock { font-weight: 800; font-variant-numeric: tabular-nums; letter-spacing: 1px; }

    /* ===== PANELS ===== */
    .tt-panel {
        background: rgba(17,17,23,0.8);
        backdrop-filter: blur(20px);
        -webkit-backdrop-filter: blur(20px);
        border: 1px solid var(--cz-border);
        border-radius: var(--cz-radius);
        padding: 20px;
        height: 100%;
        display: flex;
        flex-direction: column;
        box-shadow: 0 30px 60px rgba(0,0,0,0.4);
    }

    .tt-panel__title {
        font-size: 0.7rem;
        font-weight: 800;
        text-transform: uppercase;
        letter-spacing: 2px;
        color: var(--cz-text-muted);
        margin-bottom: 16px;
        display: flex;
        align-items: center;
        gap: 10px;
    }
    .tt-panel__title::after { content: ''; flex: 1; height: 1px; background: var(--cz-border); }

    /* ===== MOVIE INFO SECTION ===== */
    .tt-hero {
        display: flex;
        gap: 20px;
        margin-bottom: 24px;
    }

    .tt-poster {
        width: 75px;
        height: 110px;
        border-radius: 10px;
        object-fit: cover;
        box-shadow: 0 15px 40px rgba(0,0,0,0.6);
        flex-shrink: 0;
        border: 1px solid rgba(255,255,255,0.1);
    }

    .tt-info { flex: 1; display: flex; flex-direction: column; }

    .tt-movie-title {
        font-size: 1.3rem;
        font-weight: 950;
        line-height: 1.1;
        letter-spacing: -0.5px;
        margin-bottom: 12px;
        background: linear-gradient(to bottom, #fff, #bbb);
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
    }

    .tt-grid {
        display: grid;
        grid-template-columns: repeat(2, 1fr);
        gap: 12px 16px;
    }

    .tt-item { display: flex; align-items: flex-start; gap: 10px; }
    .tt-item i { width: 16px; text-align: center; color: var(--cz-accent); font-size: 0.85rem; margin-top: 2px; }
    .tt-item-label { font-size: 0.6rem; font-weight: 700; text-transform: uppercase; letter-spacing: 1px; color: var(--cz-text-muted); margin-bottom: 2px; }
    .tt-item-value { font-size: 0.88rem; font-weight: 700; color: var(--cz-text-sub); line-height: 1.3; }
    .tt-item-value--bold { color: var(--cz-text); font-weight: 800; font-size: 0.95rem; }

    /* ===== PRICE BREAKDOWN ===== */
    .tt-breakdown {
        margin-top: auto;
        padding-top: 16px;
        border-top: 1px solid var(--cz-border);
    }

    .tt-breakdown-row {
        display: flex;
        justify-content: space-between;
        margin-bottom: 8px;
        font-size: 0.85rem;
        color: var(--cz-text-sub);
    }

    .tt-breakdown-row--total {
        margin-top: 16px;
        padding-top: 16px;
        border-top: 1px dashed var(--cz-border);
        align-items: flex-end;
    }

    .tt-final-price {
        font-size: 1.8rem;
        font-weight: 950;
        color: var(--cz-accent);
        line-height: 1;
        letter-spacing: -1.5px;
        text-shadow: 0 0 25px rgba(229,9,20,0.25);
    }

    /* ===== PAYMENT CARDS (GRID 2x2) ===== */
    .tt-methods {
        display: grid;
        grid-template-columns: repeat(2, 1fr);
        gap: 12px;
    }

    .tt-card {
        background: rgba(255,255,255,0.02);
        border: 2px solid transparent;
        border-radius: 16px;
        padding: 12px;
        display: flex;
        flex-direction: column; /* Vertical alignment */
        align-items: center;
        text-align: center;
        gap: 8px;
        cursor: pointer;
        transition: all 0.3s var(--cz-ease);
        position: relative;
        overflow: hidden;
    }

    .tt-card:hover:not(.disabled) { background: rgba(255,255,255,0.05); transform: translateY(-3px); }
    .tt-card.is-active { border-color: var(--cz-accent); background: rgba(229,9,20,0.05); }

    .tt-card.disabled {
        opacity: 0.5;
        cursor: not-allowed;
        filter: grayscale(0.8);
    }

    .tt-card-icon {
        width: 40px; height: 40px;
        border-radius: 12px;
        display: flex; align-items: center; justify-content: center;
        flex-shrink: 0;
    }
    .tt-card-icon--momo { background: #ae1f6b; }
    .tt-card-icon--vnpay { background: #fff; }
    .tt-card-icon--zalo { background: #0081ff; }
    .tt-card-icon--cash { background: #222; }

    .tt-card-icon img { width: 28px; height: auto; }
    .tt-card-icon i { font-size: 20px; color: #fff; }

    .tt-card-info { margin-top: 2px; }
    .tt-card-name { font-size: 0.85rem; font-weight: 800; color: #fff; line-height: 1.2; margin-bottom: 4px; }
    .tt-card-desc { font-size: 0.65rem; color: var(--cz-text-muted); line-height: 1.2; }

    .tt-card-badge {
        position: absolute;
        top: 8px; right: 8px;
        font-size: 0.55rem;
        font-weight: 800;
        background: rgba(255,255,255,0.1);
        color: var(--cz-text-muted);
        padding: 3px 8px;
        border-radius: 4px;
        letter-spacing: 0.5px;
    }

    .tt-check {
        position: absolute;
        top: 10px; right: 10px;
        width: 22px; height: 22px;
        border-radius: 50%;
        background: var(--cz-accent);
        color: #fff;
        display: flex; align-items: center; justify-content: center;
        font-size: 0.7rem;
        opacity: 0; transform: scale(0.5);
        transition: all 0.3s cubic-bezier(0.34, 1.56, 0.64, 1);
        box-shadow: 0 4px 10px rgba(229,9,20,0.5);
    }
    .tt-card.is-active .tt-check { opacity: 1; transform: scale(1); }

    /* ===== CTA AREA ===== */
    .tt-action { margin-top: 24px; text-align: center; }

    .tt-btn {
        width: 100%;
        padding: 14px;
        background: var(--cz-accent);
        border: none;
        border-radius: 14px;
        color: #fff;
        font-size: 0.95rem;
        font-weight: 900;
        letter-spacing: 1.5px;
        text-transform: uppercase;
        cursor: pointer;
        transition: all 0.3s var(--cz-ease);
        box-shadow: 0 10px 30px rgba(229,9,20,0.3);
    }

    .tt-btn:hover {
        background: #db0812;
        transform: translateY(-4px) scale(1.01);
        box-shadow: 0 15px 40px rgba(229,9,20,0.5);
    }
    
    .tt-btn:active { transform: translateY(-2px); }

    .tt-microcopy { margin-top: 16px; font-size: 0.8rem; color: var(--cz-text-muted); display: flex; align-items: center; justify-content: center; gap: 8px; }

    /* ===== MODAL CUSTOM ===== */
    .modal-content {
        background: #111117 !important;
        border: 1px solid rgba(255,255,255,0.08) !important;
        border-radius: 28px !important;
        overflow: hidden;
        color: #fff;
        box-shadow: 0 40px 80px rgba(0,0,0,0.6);
    }
    .modal-header { border-bottom: 1px solid rgba(255,255,255,0.05) !important; padding: 28px 36px !important; position: relative; }
    .modal-body { padding: 36px !important; }
    .modal-footer { border-top: 1px solid rgba(255,255,255,0.05) !important; padding: 28px 36px !important; background: rgba(255,255,255,0.015); }
    
    .btn-close { 
        filter: invert(1) grayscale(100%) brightness(200%); 
        transition: all 0.3s var(--cz-ease);
        position: absolute; right: 28px; top: 32px;
    }
    .btn-close:hover { transform: rotate(90deg) scale(1.1); opacity: 1; }

    .tt-modal-box {
        background: #1c1c1e;
        border: 1px solid rgba(255,255,255,0.06);
        border-radius: 20px;
        padding: 20px;
        margin-bottom: 20px;
        box-shadow: inset 0 0 20px rgba(0,0,0,0.2);
    }

    .tt-m-item { display: flex; justify-content: space-between; margin-bottom: 12px; align-items: center; }
    .tt-m-label { font-size: 0.75rem; color: var(--cz-text-muted); font-weight: 500; }
    .tt-m-value { font-size: 0.88rem; font-weight: 700; color: #fff; text-align: right; }
    .tt-m-value--highlight { color: var(--cz-accent); }
    .tt-m-divider { height: 1px; border-top: 1px dashed rgba(255,255,255,0.1); margin: 12px 0; }
    
    .tt-m-total-label { font-size: 0.8rem; font-weight: 800; color: #fff; text-transform: uppercase; letter-spacing: 1px; }
    .tt-m-total-value { font-size: 1.5rem; font-weight: 950; color: var(--cz-accent); text-shadow: 0 0 15px rgba(229,9,20,0.3); }

    .tt-m-trust {
        display: flex; gap: 12px; align-items: center; 
        color: var(--cz-text-sub); font-size: 0.85rem; line-height: 1.4;
        margin-bottom: 8px;
    }
    .tt-m-trust i { font-size: 1.1rem; color: #10b981; }

    .tt-m-commitment { font-size: 0.75rem; color: var(--cz-text-muted); font-style: italic; text-align: center; margin-top: 10px; }

    .btn-netflix {
        background: var(--cz-accent); border: none; color: #fff;
        transition: all 0.3s; box-shadow: 0 4px 12px rgba(229,9,20,0.3);
    }
    .btn-netflix:hover:not(:disabled) { background: #c40812; transform: translateY(-2px); box-shadow: 0 8px 20px rgba(229,9,20,0.4); }
    .btn-netflix:disabled { opacity: 0.7; cursor: not-allowed; }

    /* ===== RESPONSIVE ===== */
    @@media (max-width: 991px) {
        .tt-page { padding-top: 100px; padding-bottom: 120px; }
        .tt-hero { flex-direction: column; align-items: center; text-align: center; }
        .tt-info { align-items: center; }
        .tt-grid { text-align: left; }
        .tt-methods { grid-template-columns: 1fr; }
        .tt-card { flex-direction: row; text-align: left; padding: 12px 16px; }
        .tt-card-info { margin-top: 0; }
        .tt-check { top: 50%; transform: translateY(-50%) scale(0.5); }
        .tt-card.is-active .tt-check { transform: translateY(-50%) scale(1); }
        .tt-breakdown-row--total { flex-direction: column; align-items: center; gap: 8px; }
        
        /* Sticky Mobile CTA */
        .tt-mobile-sticky {
            position: fixed;
            bottom: 0; left: 0; right: 0;
            background: rgba(10,10,15,0.9);
            backdrop-filter: blur(20px);
            padding: 20px;
            border-top: 1px solid var(--cz-border);
            z-index: 1000;
            display: flex;
            align-items: center;
            justify-content: space-between;
            gap: 20px;
        }

        .tt-action { margin-top: 0; }
        .tt-btn { padding: 16px; }
    }
</style>
}

<div class="tt-ambient" style="background-image: url('@posterUrl');"></div>

<div class="container tt-page" style="margin-top: 110px;">
    
    <div class="tt-header-bar">
        
        <!-- Countdown Timer -->
        <div id="payment-timer" class="tt-timer-bar">
            <i class="fas fa-hourglass-half"></i>
            <span>Giữ ghế:</span>
            <span class="tt-timer-clock" id="timer-clock">09:59</span>
        </div>
    </div>

    <div class="row g-4 align-items-stretch">

        <!-- ===== LEFT: ORDER SUMMARY ===== -->
        <div class="col-lg-7">
            <div class="tt-panel">
                <div class="tt-panel__title">Thông tin giao dịch</div>
                
                <div class="tt-hero">
                    <img src="@posterUrl" class="tt-poster" alt="Movie Poster">
                    <div class="tt-info">
                        <h1 class="tt-movie-title">@Model.LichChieu.Phim.TenPhim</h1>
                        
                        <div class="tt-grid">
                            <div class="tt-item">
                                <i class="fas fa-map-marker-alt"></i>
                                <div class="tt-item-content">
                                    <div class="tt-item-label">Rạp & Phòng</div>
                                    <div class="tt-item-value">@Model.LichChieu.PhongChieu.RapPhim.TenRap - Phòng @Model.LichChieu.PhongChieu.SoPhong</div>
                                </div>
                            </div>
                            <div class="tt-item">
                                <i class="fas fa-clock"></i>
                                <div class="tt-item-content">
                                    <div class="tt-item-label">Suất chiếu</div>
                                    <div class="tt-item-value">@Model.LichChieu.NgayChieu.ToString("dd/MM/yyyy") | @showtimeStr</div>
                                </div>
                            </div>
                            <div class="tt-item" style="grid-column: span 2;">
                                <i class="fas fa-ticket-alt"></i>
                                <div class="tt-item-content">
                                    <div class="tt-item-label">Ghế đã chọn</div>
                                    <div class="tt-item-value tt-item-value--bold">@selectedSeats</div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>

                <div class="tt-breakdown">
                    <div class="tt-breakdown-row">
                        <span>Giá vé (@ticketCount vé)</span>
                        <span>@seatTotal.ToString("N0")đ</span>
                    </div>
                    @if (Model.DatVeCombos != null && Model.DatVeCombos.Any())
                    {
                        <div class="tt-breakdown-row">
                            <span class="small">
                                @string.Join(", ", Model.DatVeCombos.Select(c => $"{c.SoLuong}x {c.Combo.TenCombo}"))
                            </span>
                            <span>@comboTotal.ToString("N0")đ</span>
                        </div>
                    }
                    <div class="tt-breakdown-row">
                        <span>Phí dịch vụ</span>
                        <span class="text-success">Miễn phí</span>
                    </div>
                    @if (discount > 0)
                    {
                    <div class="tt-breakdown-row text-success">
                        <span>Giảm giá (Voucher)</span>
                        <span>-@discount.ToString("N0")đ</span>
                    </div>
                    }

                    <div class="tt-breakdown-row tt-breakdown-row--total">
                        <div>
                            <div class="tt-total-label">Tổng thanh toán</div>
                            <div class="tt-card-desc">Bao gồm thuế phí</div>
                        </div>
                        <div class="tt-final-price">@Model.TongTien.ToString("N0")đ</div>
                    </div>
                </div>
            </div>
        </div>

        <!-- ===== RIGHT: PAYMENT METHODS ===== -->
        <div class="col-lg-5">
            <div class="tt-panel">
                <div class="tt-panel__title">Hình thức thanh toán</div>

                @if (TempData["ErrorMessage"] != null)
                {
                    <div class="alert tt-alert">
                        <i class="fas fa-exclamation-circle me-2"></i>@TempData["ErrorMessage"]
                    </div>
                }

                <div class="tt-methods">
                    <!-- MoMo Option -->
                    <div class="tt-card is-active" data-method="momo" role="button">
                        <div class="tt-card-icon tt-card-icon--momo">
                            <img src="https://img.mservice.io/momo-payment/2020/10/pa_momo.png" alt="MoMo">
                        </div>
                        <div class="tt-card-info">
                            <div class="tt-card-name">Ví điện tử MoMo</div>
                            <div class="tt-card-desc">Thanh toán tức thì</div>
                        </div>
                        <div class="tt-check"><i class="fas fa-check"></i></div>
                    </div>

                    <!-- VNPAY Option -->
                    <div class="tt-card disabled" data-method="vnpay" role="button">
                        <span class="tt-card-badge">Sắp có</span>
                        <div class="tt-card-icon tt-card-icon--vnpay">
                            <img src="https://sandbox.vnpayment.vn/paymentv2/Images/brands/logo-vnpay.png" alt="VNPAY">
                        </div>
                        <div class="tt-card-info">
                            <div class="tt-card-name">VNPAY-QR</div>
                            <div class="tt-card-desc">Quét mã QR từ ngân hàng</div>
                        </div>
                        <div class="tt-check"><i class="fas fa-check"></i></div>
                    </div>

                    <!-- ZaloPay Option -->
                    <div class="tt-card disabled" data-method="zalo" role="button">
                        <span class="tt-card-badge">Sắp có</span>
                        <div class="tt-card-icon tt-card-icon--zalo">
                            <img src="https://upload.wikimedia.org/wikipedia/vi/7/77/ZaloPay_Logo.png" alt="ZaloPay">
                        </div>
                        <div class="tt-card-info">
                            <div class="tt-card-name">Ví ZaloPay</div>
                            <div class="tt-card-desc">Ưu đãi hoàn tiền hấp dẫn</div>
                        </div>
                        <div class="tt-check"><i class="fas fa-check"></i></div>
                    </div>

                    <!-- Cash Option -->
                    <div class="tt-card" data-method="cash" role="button">
                        <div class="tt-card-icon tt-card-icon--cash">
                            <i class="fas fa-money-bill-wave"></i>
                        </div>
                        <div class="tt-card-info">
                            <div class="tt-card-name">Thanh toán tại rạp</div>
                            <div class="tt-card-desc">Giữ chỗ và lấy vé tại quầy</div>
                        </div>
                        <div class="tt-check"><i class="fas fa-check"></i></div>
                    </div>
                </div>

                <div class="tt-action tt-mobile-sticky">
                    <button type="button" id="btn-pre-confirm" class="tt-btn">
                        Tiến hành thanh toán
                    </button>
                    
                    <div class="tt-microcopy">
                        <i class="fas fa-shield-alt"></i>
                        Giao dịch được bảo mật bởi chuẩn PCI-DSS
                    </div>
                </div>
            </div>
        </div>

    </div>
</div>

<!-- ===== CONFIRMATION MODAL ===== -->
<div class="modal fade" id="confirmModal" tabindex="-1" aria-hidden="true" data-bs-backdrop="static">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title fw-bold">Xác nhận thanh toán</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body">
                <p class="small text-white-50 mb-4">Vui lòng kiểm tra kỹ thông tin đơn hàng của bạn:</p>
                
                <div class="tt-modal-box">
                    <div class="tt-m-item">
                        <span class="tt-m-label">Phim</span>
                        <span class="tt-m-value" id="m-val-movie">@Model.LichChieu.Phim.TenPhim</span>
                    </div>
                    <div class="tt-m-item">
                        <span class="tt-m-label">Rạp & Phòng</span>
                        <span class="tt-m-value">@Model.LichChieu.PhongChieu.RapPhim.TenRap - P.@Model.LichChieu.PhongChieu.SoPhong</span>
                    </div>
                    <div class="tt-m-item">
                        <span class="tt-m-label">Suất chiếu</span>
                        <span class="tt-m-value" id="m-val-showtime">@Model.LichChieu.NgayChieu.ToString("dd/MM/yyyy") @showtimeStr</span>
                    </div>
                    <div class="tt-m-item">
                        <span class="tt-m-label">Ghế đã chọn</span>
                        <span class="tt-m-value tt-m-value--highlight">@selectedSeats</span>
                    </div>
                    
                    <div class="tt-m-divider"></div>
                    
                    <div class="tt-m-item mb-0">
                        <span class="tt-m-total-label">Tổng cộng</span>
                        <span class="tt-m-total-value">@Model.TongTien.ToString("N0")đ</span>
                    </div>
                </div>

                <div class="tt-m-trust">
                    <i class="fas fa-shield-check"></i>
                    <span>Bạn sẽ được chuyển đến cổng thanh toán bảo mật để hoàn tất giao dịch an toàn.</span>
                </div>
                <div class="tt-m-commitment">
                    <i class="far fa-envelope me-1"></i> Vé điện tử sẽ được gửi qua Email sau khi thanh toán thành công
                </div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-dark border-0 px-4 py-2" data-bs-dismiss="modal" style="background: rgba(255,255,255,0.05);">Quay lại</button>
                <button type="button" id="btn-final-pay" class="btn btn-netflix px-4 py-2 fw-bold">XÁC NHẬN & THANH TOÁN</button>
            </div>
        </div>
    </div>
</div>

<!-- Hidden Forms -->
<form asp-action="ThanhToanMomo" method="post" id="form-momo" class="d-none">
    @Html.AntiForgeryToken()
    <input type="hidden" name="maDatVe" value="@Model.MaDatVe" />
</form>

<form asp-action="ThanhToanTaiRap" method="post" id="form-cash" class="d-none">
    @Html.AntiForgeryToken()
    <input type="hidden" name="maDatVe" value="@Model.MaDatVe" />
</form>

@section Scripts {
<script>
    document.addEventListener('DOMContentLoaded', function() {
        // --- PAYMENT METHOD SELECTION ---
        var pmCards = document.querySelectorAll('.tt-card:not(.disabled)');
        var selectedMethod = 'momo';

        pmCards.forEach(function(card) {
            card.addEventListener('click', function() {
                pmCards.forEach(c => c.classList.remove('is-active'));
                this.classList.add('is-active');
                selectedMethod = this.getAttribute('data-method');
            });
        });

        // --- COUNTDOWN TIMER ---
        var timeLeft = 600; // 10 minutes
        var timerClock = document.getElementById('timer-clock');
        var timerBar = document.getElementById('payment-timer');

        var countdown = setInterval(function() {
            var minutes = Math.floor(timeLeft / 60);
            var seconds = timeLeft % 60;
            
            timerClock.textContent = 
                (minutes < 10 ? '0' : '') + minutes + ':' + 
                (seconds < 10 ? '0' : '') + seconds;

            if (timeLeft <= 300) timerBar.classList.add('warning');
            if (timeLeft <= 60) timerBar.classList.add('danger');

            if (timeLeft <= 0) {
                clearInterval(countdown);
                alert('Thời gian giữ ghế đã hết. Vui lòng đặt vé lại.');
                window.location.href = '@Url.Action("Index", "DatVe", new { maPhim = Model.LichChieu.MaPhim })';
            }
            timeLeft--;
        }, 1000);

        // --- SUBMIT FLOW ---
        var confirmModal = new bootstrap.Modal(document.getElementById('confirmModal'));
        var btnPre = document.getElementById('btn-pre-confirm');
        var btnFinal = document.getElementById('btn-final-pay');

        btnPre.addEventListener('click', function() {
            // Backup check: Ensure movie title is populated (Fix for the reported data issue)
            const movieTitleOnPage = document.querySelector('.tt-movie-title')?.innerText;
            const modalMovieTitle = document.getElementById('m-val-movie');
            if (movieTitleOnPage && (!modalMovieTitle.innerText || modalMovieTitle.innerText.trim() === '')) {
                modalMovieTitle.innerText = movieTitleOnPage;
            }

            confirmModal.show();
        });

        btnFinal.addEventListener('click', function() {
            // Loading State & Prevent Spam
            this.disabled = true;
            const originalHTML = this.innerHTML;
            this.innerHTML = '<i class="fas fa-spinner fa-spin me-2"></i>ĐANG XỬ LÝ...';
            
            // Commitment note for loading
            const commitment = document.querySelector('.tt-m-commitment');
            if(commitment) commitment.innerHTML = '<span class="text-success pulse">Đang kết nối đến cổng thanh toán bảo mật...</span>';

            setTimeout(function() {
                if (selectedMethod === 'momo') {
                    document.getElementById('form-momo').submit();
                } else {
                    document.getElementById('form-cash').submit();
                }
            }, 500); // Small delay for UX feel
        });
    });
</script>
}
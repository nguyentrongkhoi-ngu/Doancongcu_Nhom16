/* Root reset — force color on entire subtree */
.mvd-root {
    font-family: 'Outfit', 'Inter', system-ui, sans-serif !important;
    color: #e8e8e8 !important;
}

/* Kill site.css "body:not(.home-page) main .container { color:#212529 }" by

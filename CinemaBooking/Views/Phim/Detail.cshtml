/* ── Variables ── */
:root {
    --rd-bg:      #0d0d12;
    --rd-card:    #14141c;
    --rd-card2:   #1a1a26;
    --rd-border:  #28283a;
    --rd-text:    #f0f0f8;
    --rd-muted:   #8888a0;
    --rd-primary: #e5431a;      /* warm red-orange like reference */
    --rd-accent:  #f5c518;      /* gold star */
    --rd-green:   #22c55e;
    --rd-radius:  0.75rem;
}

/* ── Page wrapper ── */
.rd-page {
    background: var(--rd-bg);
    color: var(--rd-text);
    font-family: 'Outfit', 'Inter', sans-serif;

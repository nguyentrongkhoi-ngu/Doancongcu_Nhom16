                            </div>
                            <div class="info-item">
                                <i class="far fa-clock me-2"></i>
                                <span>@movie.ThoiLuong phút</span>
                            </div>
                            <span class="genre-tag">@movie.TheLoai</span>
                        </div>
                        
                        <p class="hero-desc mb-5">
                            @if (!string.IsNullOrEmpty(movie.MoTa))
                            {
                                @(movie.MoTa.Length > 180 ? movie.MoTa.Substring(0, 177) + "..." : movie.MoTa)
                            }
                            else
                            {
                                <span>Trải nghiệm siêu phẩm điện ảnh đỉnh cao chỉ có tại hệ thống rạp CineZore. Đặt vé ngay để nhận vị trí ngồi tốt nhất!</span>
                            }
                        </p>
                        
                        <div class="hero-cta-group">
                            <a asp-controller="DatVe" asp-action="Index" asp-route-maPhim="@movie.MaPhim" 

                                <i class="fas fa-ticket-alt me-2"></i> ĐẶT VÉ NGAY
                            </a>
                            <a asp-controller="Phim" asp-action="Detail" asp-route-id="@movie.MaPhim" 
                               class="btn-cz-outline btn-lg-cz">
                                <i class="fas fa-play me-2"></i> XEM TRAILER

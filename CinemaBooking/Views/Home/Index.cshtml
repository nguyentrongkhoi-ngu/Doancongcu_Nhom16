        <div class="swiper-pagination-custom"></div>
        <div class="swiper-nav swiper-prev"><i class="fas fa-chevron-left"></i></div>
        <div class="swiper-nav swiper-next"><i class="fas fa-chevron-right"></i></div>
    </section>
}

<!-- QUICK BOOKING BAR -->
<div class="quick-booking-wrapper">
    <div class="container">
        <form asp-controller="DatVe" asp-action="Index" method="get" class="quick-booking-bar">
            <div class="qb-field">
                <label><i class="fas fa-film me-2"></i>Chọn phim</label>
                <select name="maPhim" class="form-select-cz" required>
                    <option value="">Phim bạn muốn xem?</option>
                    @if (nowShowing != null)
                    {
                        @foreach (var p in nowShowing)
                        {
                            <option value="@p.MaPhim">@p.TenPhim</option>
                        }
                    }
                </select>
            </div>
            
            <div class="qb-field">
                <label><i class="fas fa-map-marker-alt me-2"></i>Chọn rạp</label>
                <select name="maRap" class="form-select-cz">
                    <option value="">Gần bạn nhất</option>
                    @if (ViewBag.Cinemas != null)
                    {
                        @foreach (var r in ViewBag.Cinemas as IEnumerable<CinemaBooking.Models.RapPhim>)
                        {
                            <option value="@r.MaRap">@r.TenRap</option>
                        }
                    }
                </select>
            </div>
            
            <div class="qb-field">
                <label><i class="fas fa-calendar-day me-2"></i>Chọn ngày</label>
                <select name="ngayChieu" class="form-select-cz">
                    <option value="@DateTime.Now.ToString("yyyy-MM-dd")">Hôm nay, @DateTime.Now.ToString("dd/MM")</option>
                    <option value="@DateTime.Now.AddDays(1).ToString("yyyy-MM-dd")">Ngày mai, @DateTime.Now.AddDays(1).ToString("dd/MM")</option>
                    <option value="@DateTime.Now.AddDays(2).ToString("yyyy-MM-dd")">@DateTime.Now.AddDays(2).ToString("dddd, dd/MM")</option>
                </select>
            </div>
            
            <button type="submit" class="btn-qb-submit">
                <i class="fas fa-search me-2"></i> ĐẶT VÉ NHANH
            </button>
        </form>
    </div>
</div>


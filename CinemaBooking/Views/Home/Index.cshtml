<!-- ═══════════════ HERO ═══════════════ -->
@if (firstMovie != null)
{
    <section class="hero-section" id="heroSection"
             style="background-image: url('@(string.IsNullOrEmpty(firstMovie.UrlPoster) ? "/images/no-image.jpg" : firstMovie.UrlPoster)');">
        <div class="hero-overlay"></div>
        <div class="hero-content">

            <!-- Featured badge -->
            <div class="hero-badge">
                <i class="fas fa-fire" style="font-size:0.55rem;"></i> Nổi bật
            </div>

            <!-- Meta info -->
            <div class="hero-meta-badges">
                @if (firstMovie.NgayPhatHanh.HasValue)
                {
                    <span class="badge">@firstMovie.NgayPhatHanh.Value.Year</span>
                }
                @if (!string.IsNullOrEmpty(firstMovie.TheLoai))
                {
                    <span class="badge">@firstMovie.TheLoai</span>
                }
                <span class="badge" style="color:rgba(100,220,120,0.9) !important; border-color:rgba(100,220,120,0.25) !important;">
                    <i class="fas fa-circle" style="font-size:0.4rem; vertical-align:middle; margin-right:4px;"></i>Đang chiếu
                </span>
            </div>

            <!-- Title -->
            <h1 class="display-2 fw-bold text-white">@firstMovie.TenPhim</h1>

            <!-- Description -->
            @if (!string.IsNullOrEmpty(firstMovie.MoTa))
            {
                <p class="lead">
                    @(firstMovie.MoTa.Length > 160 ? firstMovie.MoTa.Substring(0, 160) + "…" : firstMovie.MoTa)
                </p>
            }

            <!-- CTA -->
            <div class="hero-cta">
                <a asp-controller="DatVe" asp-action="Index" asp-route-maPhim="@firstMovie.MaPhim" class="btn btn-netflix">
                    <i class="fas fa-ticket-alt"></i> Đặt vé ngay
                </a>
                <a asp-controller="Phim" asp-action="Detail" asp-route-id="@firstMovie.MaPhim" class="btn btn-netflix-gray">
                    <i class="fas fa-play-circle"></i> Xem chi tiết
                </a>
            </div>

        </div>
    </section>
}


                        </div>
                        
                        <h1 class="hero-title mb-3">@(movie.TenPhim ?? "Unknown Title")</h1>
                        
                        <div class="hero-info-row mb-4">
                            @if (movie.DiemIMDb.HasValue)
                            {
                                <div class="info-item">
                                    <i class="fas fa-star text-warning me-2"></i>
                                    <span class="fw-bold">@movie.DiemIMDb.Value.ToString("0.0")</span>

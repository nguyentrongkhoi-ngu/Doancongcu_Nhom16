@model IEnumerable<CinemaBooking.Models.DatVe>
@using System.Globalization

@{
    ViewData["Title"] = "Lịch sử đặt vé";
}

<div class="container" style="padding-top: 120px; min-height: 80vh;">
    <div class="row align-items-center mb-4">
        <div class="col-md-8">
            <h1 class="text-white fw-bold">Lịch sử đặt vé</h1>
            <p class="text-white-50">Xem lại các bộ phim bạn đã đặt và quản lý vé của mình.</p>
        </div>
        <div class="col-md-4 text-md-end">
            <a href="@Url.Action("TicketHelp", "Home")" class="btn btn-netflix-gray">
                <i class="fas fa-question-circle me-2"></i>Hướng dẫn in vé
            </a>
        </div>
    </div>

    <!-- Chính sách hủy vé (Glassmorphism) -->
    <div class="glass-panel border-start border-netflix border-4 mb-5" id="policyAlert" style="background: rgba(229, 9, 20, 0.05);">
        <div class="d-flex justify-content-between align-items-start">
            <div>
                <h5 class="text-netflix fw-bold"><i class="fas fa-info-circle me-2"></i>Chính sách đặt & hủy vé</h5>
                <ul class="text-white-50 small mb-0 mt-2">
                    <li>Vé chưa thanh toán: Có thể hủy miễn phí trước 4 giờ so với giờ chiếu.</li>
                    <li>Vé đã thanh toán: <strong>Không hoàn tiền</strong> trong mọi trường hợp, chỉ có thể hủy trước 4 giờ.</li>
                </ul>
            </div>
            <button type="button" class="btn-close btn-close-white" id="closePolicyBtn"></button>
        </div>
    </div>

    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show mb-4" role="alert">
            <i class="fas fa-check-circle me-2"></i>@TempData["SuccessMessage"]
            <button type="button" class="btn-close btn-close-white" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    @if (TempData["ErrorMessage"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show mb-4" role="alert">
            <i class="fas fa-exclamation-circle me-2"></i>@TempData["ErrorMessage"]
            <button type="button" class="btn-close btn-close-white" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    @if (!Model.Any())
    {
        <div class="glass-panel text-center py-5">
            <i class="fas fa-ticket-alt display-1 text-white-50 mb-3"></i>
            <h4 class="text-white">Bạn chưa có vé đặt nào</h4>
            <p class="text-white-50 mb-4">Hãy khám phá các phim đang chiếu và đặt vé ngay!</p>
            <a href="@Url.Action("Index", "Home")" class="btn btn-netflix">KHÁM PHÁ NGAY</a>
        </div>
    }
    else
    {
        <div class="row g-4">
            @foreach (var datVe in Model)
            {
                <div class="col-12">
                    <div class="glass-panel p-0 overflow-hidden border-0 hover-lift">
                        <div class="row g-0">
                            <!-- Movie Poster Thumbnail -->
                            <div class="col-md-2 d-none d-md-block">
                                <img src="@(string.IsNullOrEmpty(datVe.LichChieu.Phim.UrlPoster) ? "/images/no-image.jpg" : datVe.LichChieu.Phim.UrlPoster)" 
                                     class="img-fluid h-100 w-100" style="object-fit: cover;" alt="Poster">
                            </div>
                            <!-- Ticket Content -->
                            <div class="col-md-10 p-4">
                                <div class="d-flex justify-content-between align-items-start mb-3">
                                    <div>
                                        <h4 class="text-white fw-bold mb-1">@datVe.LichChieu.Phim.TenPhim</h4>
                                        <div class="text-white-50 small">
                                            <i class="fas fa-map-marker-alt me-1 text-netflix"></i> @datVe.LichChieu.PhongChieu.RapPhim.TenRap - Phòng @datVe.LichChieu.PhongChieu.SoPhong
                                        </div>
                                    </div>
                                    <span class="badge @(datVe.TrangThai == "Đã thanh toán" ? "bg-success bg-opacity-75" : 
                                                         datVe.TrangThai == "Chưa thanh toán" ? "bg-warning text-dark" : 
                                                         datVe.TrangThai.Contains("Đã hủy") ? "bg-danger bg-opacity-75" : "bg-secondary") px-3 py-2">
                                        @datVe.TrangThai
                                    </span>
                                </div>

                                <div class="row g-3 mb-4">
                                    <div class="col-sm-3">
                                        <div class="text-white-50 small">Ngày chiếu</div>
                                        <div class="text-white">@datVe.LichChieu.NgayChieu.ToString("dd/MM/yyyy")</div>
                                    </div>
                                    <div class="col-sm-2">
                                        <div class="text-white-50 small">Giờ chiếu</div>
                                        <div class="text-white">@($"{datVe.LichChieu.GioChieu.Hours:D2}:{datVe.LichChieu.GioChieu.Minutes:D2}")</div>
                                    </div>
                                    <div class="col-sm-3">
                                        <div class="text-white-50 small">Ghế ngồi</div>
                                        <div class="text-white">
                                            @if (datVe.TrangThai.Contains("Đã hủy") && !string.IsNullOrEmpty(datVe.GhiChu))
                                            {
                                                @(datVe.GhiChu.Contains("Ghế đã đặt:") ? datVe.GhiChu.Replace("Ghế đã đặt: ", "") : datVe.GhiChu)
                                            }
                                            else if (datVe.DatVeGhes != null && datVe.DatVeGhes.Any())
                                            {
                                                @string.Join(", ", datVe.DatVeGhes.Select(c => c.Ghe.SoGhe))
                                            }
                                            else { <span class="text-white-50">N/A</span> }
                                        </div>
                                    </div>
                                    <div class="col-sm-4 text-md-end">
                                        <div class="text-white-50 small">Tổng cộng</div>
                                        <div class="text-netflix fs-4 fw-bold">@string.Format("{0:N0}đ", datVe.TongTien)</div>
                                    </div>
                                </div>

                                <div class="d-flex justify-content-between align-items-center pt-3 border-top border-secondary border-opacity-25">
                                    <div class="text-white-50 small">
                                        <i class="far fa-clock me-1"></i>Đặt lúc: @(datVe.NgayDat.HasValue ? datVe.NgayDat.Value.ToString("dd/MM/yyyy HH:mm") : "N/A")
                                    </div>
                                    <div class="d-flex gap-2">
                                        @if (!datVe.TrangThai.Contains("Đã hủy"))
                                        {
                                            <div class="btn-group">
                                                <a href="@Url.Action("Print", "DatVe", new { maDatVe = datVe.MaDatVe })" class="btn btn-netflix-gray btn-sm">
                                                    <i class="fas fa-print me-1"></i>In vé
                                                </a>
                                                <button type="button" class="btn btn-netflix-gray btn-sm dropdown-toggle dropdown-toggle-split" data-bs-toggle="dropdown"></button>
                                                <ul class="dropdown-menu dropdown-menu-dark">
                                                    <li><a class="dropdown-item" href="@Url.Action("Print", "DatVe", new { maDatVe = datVe.MaDatVe })">In vé tổng hợp</a></li>
                                                    <li><a class="dropdown-item" href="@Url.Action("PrintMultiple", "DatVe", new { maDatVe = datVe.MaDatVe })">In vé từng ghế</a></li>
                                                </ul>
                                            </div>

                                            if (datVe.TrangThai == "Chưa thanh toán" || datVe.TrangThai == "Chờ thanh toán")
                                            {
                                                <a href="@Url.Action("Index", "ThanhToan", new { maDatVe = datVe.MaDatVe })" class="btn btn-netflix btn-sm">
                                                    <i class="fas fa-credit-card me-1"></i>Thanh toán ngay
                                                </a>
                                            }

                                            <form asp-controller="DatVe" asp-action="HuyVe" method="post" class="cancel-form">
                                                @Html.AntiForgeryToken()
                                                <input type="hidden" name="maDatVe" value="@datVe.MaDatVe" />
                                                <button type="submit" class="btn btn-netflix-gray btn-sm text-danger border-danger border-opacity-25">
                                                    <i class="fas fa-times me-1"></i>Hủy vé
                                                </button>
                                            </form>
                                        }
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            }
        </div>
    }
</div>

@section Styles {
    <style>
        .hover-lift {
            transition: transform 0.3s ease, background 0.3s ease;
        }
        .hover-lift:hover {
            transform: translateY(-5px);
            background: rgba(255, 255, 255, 0.1) !important;
        }
        .btn-netflix-gray {
            border: 1px solid rgba(255,255,255,0.3);
        }
    </style>
}

@section Scripts {
    <script>
        $(document).ready(function() {
            // Close Policy
            $("#closePolicyBtn").click(function() {
                $("#policyAlert").fadeOut();
            });

            // Cancel Form
            $(".cancel-form").on('submit', function(e) {
                const isPaid = $(this).closest('.p-4').find('.badge').hasClass('bg-success');
                const msg = isPaid 
                    ? "Lưu ý: Vé đã thanh toán sẽ KHÔNG được hoàn tiền khi hủy. Bạn chắc chắn chứ?" 
                    : "Bạn có chắc chắn muốn hủy vé này?";
                return confirm(msg);
            });
        });
    </script>
}
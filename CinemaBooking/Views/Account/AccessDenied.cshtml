@{
    ViewData["Title"] = "Truy Cập Bị Từ Chối - CineZore 2026";
    Layout = "_Layout";
}

<div class="container min-vh-100 d-flex align-items-center justify-content-center">
    <div class="row w-100 justify-content-center">
        <div class="col-md-8 col-lg-6">
            <div class="access-denied-card text-center p-5 shadow-lg border border-danger">
                <div class="denied-icon-container mb-4">
                    <i class="fas fa-user-shield fa-5x text-danger animate-pulse"></i>
                    <div class="glow-effect-red"></div>
                </div>
                
                <h1 class="display-4 fw-bold text-white mb-3">TRUY CẬP BỊ CHẶN</h1>
                <p class="lead text-white-50 mb-4">
                    Bạn không có quyền truy cập vào khu vực quản trị viên này. 
                    Mọi hành động truy cập trái phép đều được ghi nhận lại trong hệ thống.
                </p>

                <div class="alert alert-danger bg-dark border-danger text-danger mb-5">
                    <i class="fas fa-exclamation-triangle me-2"></i>
                    <strong>Hành động của bạn đã bị từ chối bởi hệ thống bảo mật CineZore.</strong>
                </div>

                <div class="d-grid gap-3 d-sm-flex justify-content-sm-center">
                    <a asp-controller="Home" asp-action="Index" class="btn btn-netflix btn-lg px-4 gap-3">
                        <i class="fas fa-home me-2"></i>Về Trang Chủ
                    </a>
                    <a asp-controller="Account" asp-action="Logout" class="btn btn-outline-light btn-lg px-4">
                        <i class="fas fa-sign-out-alt me-2"></i>Đăng Xuất
                    </a>
                </div>
            </div>
        </div>
    </div>
</div>

<style>
    .access-denied-card {
        background: rgba(10, 10, 10, 0.9);
        backdrop-filter: blur(20px);
        border-radius: 20px;
        position: relative;
        overflow: hidden;
    }

    .denied-icon-container {
        position: relative;
        display: inline-block;
    }

    .glow-effect-red {
        position: absolute;
        top: 50%;
        left: 50%;
        transform: translate(-50%, -50%);
        width: 120px;
        height: 120px;
        background: radial-gradient(circle, rgba(229, 9, 20, 0.3) 0%, transparent 70%);
        z-index: -1;
        animation: pulse-glow 2s infinite ease-in-out;
    }

    .animate-pulse {
        animation: pulse-icon 2s infinite ease-in-out;
    }

    @@keyframes pulse-icon {
        0%, 100% { transform: scale(1); filter: brightness(1); }
        50% { transform: scale(1.1); filter: brightness(1.3); }
    }

    @@keyframes pulse-glow {
        0%, 100% { transform: translate(-50%, -50%) scale(1); opacity: 0.5; }
        50% { transform: translate(-50%, -50%) scale(1.5); opacity: 0.8; }
    }

    .btn-netflix {
        background-color: #e50914;
        border-color: #e50914;
        color: #fff;
        transition: all 0.3s ease;
    }

    .btn-netflix:hover {
        background-color: #f6121d;
        border-color: #f6121d;
        transform: translateY(-2px);
        box-shadow: 0 5px 15px rgba(229, 9, 20, 0.4);
    }
</style>

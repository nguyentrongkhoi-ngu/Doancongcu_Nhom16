@model CinemaBooking.Models.ViewModels.ForgotPasswordViewModel

@{
    Layout = null; // Clean page with floating card
}

<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Khôi phục mật khẩu - CineZore 2026</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Outfit:wght@400;700;900&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="~/css/auth-obsidian.css" asp-append-version="true" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css" />
</head>
<body class="auth-page">
    <div class="spatial-grid"></div>

    <div class="auth-viewport">
        <div class="obsidian-card" id="forgotCard">
            <div class="corner-accent corner-tl"></div>
            <div class="corner-accent corner-tr"></div>
            <div class="corner-accent corner-bl"></div>
            <div class="corner-accent corner-br"></div>

            <div class="auth-header">
                <h1>
                    @if (Model.Buoc == 1) { <text>Khôi phục</text> }
                    else if (Model.Buoc == 2) { <text>Xác thực</text> }
                    else { <text>Mật khẩu mới</text> }
                </h1>
                
                @if (TempData["OtpMessage"] != null)
                {
                    <div class="alert alert-success" style="font-size: 0.75rem; background: rgba(40, 167, 69, 0.1); border-left: 3px solid #28a745; color: #52be71; padding: 10px; margin-bottom: 20px;">
                        <i class="fas fa-check-circle me-2"></i> @TempData["OtpMessage"]
                    </div>
                }
            </div>

            <form asp-action="ForgotPassword" method="post" id="forgotForm">
                <div asp-validation-summary="ModelOnly" class="text-danger mb-3 small" style="font-size: 0.7rem; text-transform: uppercase; letter-spacing: 1px;"></div>
                <input type="hidden" asp-for="Buoc" />
                <input type="hidden" asp-for="DaGuiOTP" />

                @if (Model.Buoc == 1)
                {
                    <div class="auth-step active" id="step1">
                        <p class="text-white-50 mb-4" style="font-size: 0.8rem; line-height: 1.6;">
                            Nhập địa chỉ email của bạn. Chúng tôi sẽ gửi mã OTP để bắt đầu quá trình khôi phục.
                        </p>
                        <div class="obsidian-input-group">
                            <label asp-for="Email" class="obsidian-label"></label>
                            <input asp-for="Email" class="obsidian-input" placeholder="EMAIL ADDRESS" required />
                            <span asp-validation-for="Email" class="text-danger small" style="font-size: 0.65rem;"></span>
                        </div>
                        <button type="submit" class="btn-precision">
                            GỬI MÃ KHÔI PHỤC
                        </button>
                    </div>
                }
                else if (Model.Buoc == 2)
                {
                    <div class="auth-step active" id="step2">
                        <input type="hidden" asp-for="Email" />
                        <p class="text-white-50 mb-4" style="font-size: 0.8rem; line-height: 1.6;">
                            Mã xác thực đã được gửi đến <strong>@Model.Email</strong>.
                        </p>
                        <div class="obsidian-input-group">
                            <label asp-for="MaXacThuc" class="obsidian-label"></label>
                            <input asp-for="MaXacThuc" class="obsidian-input" placeholder="000000" maxlength="6" style="text-align: center; font-size: 1.5rem; letter-spacing: 12px; font-weight: 900;" required autocomplete="off" />
                            <span asp-validation-for="MaXacThuc" class="text-danger small" style="font-size: 0.65rem;"></span>
                        </div>
                        <button type="submit" class="btn-precision">
                            XÁC THỰC MÃ
                        </button>
                        <div class="mt-4 text-center">
                            <a href="@Url.Action("ResendForgotPasswordOtp")" class="text-white-50 text-decoration-none small hover-white" style="font-size: 0.7rem; letter-spacing: 1px;">
                                <i class="fas fa-redo me-1"></i> GỬI LẠI MÃ
                            </a>
                        </div>
                    </div>
                }
                else if (Model.Buoc == 3)
                {
                    <div class="auth-step active" id="step3">
                        <input type="hidden" asp-for="Email" />
                        <div class="obsidian-input-group">
                            <label asp-for="MatKhauMoi" class="obsidian-label">Mật khẩu mới</label>
                            <input asp-for="MatKhauMoi" type="password" class="obsidian-input" placeholder="••••••••" required />
                            <span asp-validation-for="MatKhauMoi" class="text-danger small" style="font-size: 0.65rem;"></span>
                        </div>
                        <div class="obsidian-input-group">
                            <label asp-for="XacNhanMatKhauMoi" class="obsidian-label">Xác nhận mật khẩu</label>
                            <input asp-for="XacNhanMatKhauMoi" type="password" class="obsidian-input" placeholder="••••••••" required />
                            <span asp-validation-for="XacNhanMatKhauMoi" class="text-danger small" style="font-size: 0.65rem;"></span>
                        </div>
                        <button type="submit" class="btn-precision">
                            CẬP NHẬT TRUY CẬP
                        </button>
                    </div>
                }
            </form>

            <div class="auth-nav-links">
                Quay lại <a href="@Url.Action("Login", "Account")" style="text-transform: uppercase; letter-spacing: 1px;">Đăng nhập</a>
            </div>
        </div>
    </div>

    <script src="https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.5/gsap.min.js"></script>
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/jquery-validation/dist/jquery.validate.min.js"></script>
    <script src="~/lib/jquery-validation-unobtrusive/jquery.validate.unobtrusive.min.js"></script>
    
    <script>
        document.addEventListener('DOMContentLoaded', () => {
            // Entrance
            gsap.from("#forgotCard", { duration: 1.2, y: 100, opacity: 0, rotationX: -20, ease: "expo.out" });
            
            // Interaction
            const card = document.querySelector('#forgotCard');
            document.addEventListener('mousemove', (e) => {
                const xAxis = (window.innerWidth / 2 - e.pageX) / 60;
                const yAxis = (window.innerHeight / 2 - e.pageY) / 60;
                gsap.to(card, { rotationY: xAxis, rotationX: -yAxis, duration: 0.5 });
            });
        });
    </script>
</body>
</html>
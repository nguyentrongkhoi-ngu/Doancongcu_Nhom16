@model IEnumerable<CinemaBooking.Models.RapPhim>

@{
    ViewData["Title"] = "Hệ thống Rạp chiếu";
    Layout = "~/Views/Shared/_Layout.cshtml";
    var cities = ViewBag.Cities as List<string>;
    var currentCity = ViewBag.CurrentCity as string;
    var currentName = ViewBag.CurrentName as string;
}

<div class="cinema-listing-page">
    <!-- Hero Header -->
    <section class="cinema-hero-cz">
        <div class="hero-overlay"></div>
        <div class="container text-center py-5 position-relative">
            <h1 class="display-4 fw-800 mb-2">Hệ thống Rạp CineZore</h1>
            <p class="lead opacity-75">Trải nghiệm không gian xem phim đẳng cấp quốc tế tại rạp gần nhất</p>
        </div>
    </section>

    <div class="container pb-5">
        <!-- Filter Bar -->
        <div class="cinema-filter-section mb-5">
            <form asp-action="Index" method="get" class="row g-3 align-items-center">
                <div class="col-md-5">
                    <div class="filter-input-group">
                        <i class="fas fa-search"></i>
                        <input type="text" name="nameSearch" class="filter-input" value="@currentName" placeholder="Tìm tên rạp..." autocomplete="off">
                    </div>
                </div>
                <div class="col-md-4">
                    <div class="filter-input-group">
                        <i class="fas fa-map-marker-alt"></i>
                        <select name="citySearch" class="filter-select">
                            <option value="">Tất cả thành phố</option>
                            @if (cities != null)
                            {
                                @foreach (var city in cities)
                                {
                                    <option value="@city" selected="@(currentCity == city)">@city</option>
                                }
                            }
                        </select>
                    </div>
                </div>
                <div class="col-md-3">
                    <button type="submit" class="btn-cz-primary w-100 py-3">Tìm kiếm rạp</button>
                </div>
            </form>
        </div>

        <!-- Cinema Grid -->
        <div class="cinema-grid-cz">
            @if (Model != null && Model.Any())
            {
                <div class="row g-4">
                    @foreach (var cinema in Model)
                    {
                        <div class="col-lg-4 col-md-6">
                            <div class="cinema-card-cz" onclick="location.href='@Url.Action("Index", "Phim", new { maRap = cinema.MaRap })'">
                                <div class="cinema-img">
                                    <img src="https://images.unsplash.com/photo-1489599849927-2ee91cede3ba?q=80&w=2070&auto=format&fit=crop" alt="@cinema.TenRap">
                                    <div class="cinema-overlay">
                                        <span class="city-tag"><i class="fas fa-map-marker-alt me-2"></i>@cinema.ThanhPho</span>
                                    </div>
                                </div>
                                <div class="cinema-info">
                                    <div class="d-flex justify-content-between align-items-start mb-2">
                                        <h5 class="cinema-title-cz">@cinema.TenRap</h5>
                                    </div>
                                    <p class="cinema-address-cz"><i class="bi bi-geo-alt me-2"></i>@cinema.DiaChi</p>
                                    <div class="cinema-meta mt-3">
                                        <div class="d-flex justify-content-between align-items-center">
                                            <span class="room-count">@(cinema.PhongChieus?.Count ?? 8) phòng chiếu</span>
                                            <a href="@Url.Action("Index", "Phim", new { maRap = cinema.MaRap })" class="btn-view-schedule">
                                                Xem lịch chiếu <i class="fas fa-chevron-right ms-2"></i>
                                            </a>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    }
                </div>
            }
            else
            {
                <div class="no-results-cz text-center py-5">
                    <i class="fas fa-map-marked-alt fa-4x mb-4 opacity-25"></i>
                    <h3>Không tìm thấy rạp chiếu nào phù hợp</h3>
                    <p class="text-white-50">Vui lòng điều chỉnh lại bộ lọc hoặc tìm kiếm theo tên khác.</p>
                    <a asp-action="Index" class="btn-cz-outline mt-3">Hiển thị tất cả rạp</a>
                </div>
            }
        </div>
    </div>
</div>

@section Styles {
    <style>
        .cinema-hero-cz {
            background: linear-gradient(rgba(10, 10, 10, 0.4), var(--netflix-dark)), 
                        url('https://images.unsplash.com/photo-1440404653325-ab127d49abc1?q=80&w=2070&auto=format&fit=crop');
            background-size: cover;
            background-position: center;
            padding: 8rem 0 4rem;
            margin-bottom: 3rem;
            position: relative;
        }

        .cinema-filter-section {
            background: rgba(255, 255, 255, 0.05);
            padding: 2rem;
            border-radius: 20px;
            border: 1px solid rgba(255, 255, 255, 0.1);
            backdrop-filter: blur(10px);
        }

        .filter-input-group {
            position: relative;
            background: rgba(10, 10, 10, 0.6);
            border: 1px solid rgba(255, 255, 255, 0.1);
            border-radius: 12px;
            overflow: hidden;
            display: flex;
            align-items: center;
            padding: 0 15px;
            transition: all 0.3s ease;
        }

        .filter-input-group:focus-within {
            border-color: var(--netflix-red);
            box-shadow: 0 0 15px rgba(229, 9, 20, 0.2);
        }

        .filter-input-group i { color: rgba(255, 255, 255, 0.4); }
        
        .filter-input, .filter-select {
            background: transparent;
            border: none;
            color: #fff;
            padding: 12px 10px;
            width: 100%;
            outline: none;
        }

        .filter-select option { background: #141414; color: #fff; }

        .cinema-card-cz {
            background: #1a1a1a;
            border-radius: 16px;
            overflow: hidden;
            transition: all 0.4s cubic-bezier(0.165, 0.84, 0.44, 1);
            border: 1px solid rgba(255, 255, 255, 0.05);
            height: 100%;
            cursor: pointer;
        }

        .cinema-card-cz:hover {
            transform: translateY(-10px);
            border-color: rgba(229, 9, 20, 0.4);
            box-shadow: 0 20px 40px rgba(0, 0, 0, 0.4);
        }

        .cinema-img {
            height: 220px;
            position: relative;
            overflow: hidden;
        }

        .cinema-img img {
            width: 100%;
            height: 100%;
            object-fit: cover;
            transition: transform 0.8s ease;
        }

        .cinema-card-cz:hover .cinema-img img { transform: scale(1.1); }

        .cinema-overlay {
            position: absolute;
            top: 20px;
            left: 20px;
            z-index: 2;
        }

        .city-tag {
            background: rgba(10, 10, 10, 0.7);
            backdrop-filter: blur(5px);
            padding: 6px 14px;
            border-radius: 30px;
            font-size: 0.8rem;
            font-weight: 600;
            border: 1px solid rgba(255, 255, 255, 0.2);
        }

        .cinema-info { padding: 1.5rem; }

        .cinema-title-cz {
            font-weight: 700;
            font-size: 1.25rem;
            color: #fff;
            margin-bottom: 0.5rem;
        }

        .cinema-address-cz {
            font-size: 0.9rem;
            color: rgba(255, 255, 255, 0.6);
            line-height: 1.5;
            margin-bottom: 0;
            display: -webkit-box;
            -webkit-line-clamp: 2;
            -webkit-box-orient: vertical;
            overflow: hidden;
        }

        .cinema-meta {
            padding-top: 1rem;
            border-top: 1px solid rgba(255, 255, 255, 0.05);
        }

        .room-count {
            font-size: 0.8rem;
            color: var(--netflix-red);
            font-weight: 700;
            text-transform: uppercase;
            letter-spacing: 0.5px;
        }

        .btn-view-schedule {
            color: #fff;
            text-decoration: none !important;
            font-size: 0.9rem;
            font-weight: 600;
            transition: all 0.3s ease;
        }

        .btn-view-schedule:hover { color: var(--netflix-red); transform: translateX(5px); }

        .btn-cz-primary {
            background: var(--netflix-red);
            color: #fff;
            border: none;
            border-radius: 12px;
            font-weight: 700;
            transition: all 0.3s ease;
        }

        .btn-cz-primary:hover {
            background: #b20710;
            transform: scale(1.02);
        }
    </style>
}

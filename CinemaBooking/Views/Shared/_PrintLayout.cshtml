<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Cinema Booking</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/5.15.4/css/all.min.css" />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;600;800&family=Outfit:wght@300;500;700;900&display=swap" rel="stylesheet">
    <style>
        :root {
            --netflix-red: #e50914;
            --ticket-bg: #ffffff;
            --ticket-text: #141414;
            --ticket-accent: #8c8c8c;
        }

        body {
            font-family: 'Outfit', sans-serif;
            background-color: #f0f0f0;
            color: var(--ticket-text);
        }

        @@media print {
            body {
                background-color: white !important;
                margin: 0;
                padding: 0;
            }
            .d-print-none {
                display: none !important;
            }
            .print-container {
                width: 100% !important;
                max-width: none !important;
                padding: 0 !important;
                margin: 0 !important;
            }
            .ticket-container {
                box-shadow: none !important;
                border: 1px solid #ddd !important;
                margin: 0 auto !important;
            }
        }

        .print-container {
            max-width: 850px;
            margin: 40px auto;
            padding: 0 15px;
        }

        /* Cinematic Ticket Style */
        .ticket-container {
            display: flex;
            flex-direction: column;
            background-color: var(--ticket-bg);
            border-radius: 16px;
            overflow: hidden;
            box-shadow: 0 20px 50px rgba(0,0,0,0.15);
            position: relative;
            margin-bottom: 40px;
            border: 1px solid rgba(0,0,0,0.05);
        }

        .ticket-main {
            display: flex;
            position: relative;
            min-height: 400px;
        }

        .ticket-visual {
            width: 280px;
            background-color: #000;
            position: relative;
            overflow: hidden;
            display: flex;
            align-items: center;
            justify-content: center;
            flex-shrink: 0;
        }

        .ticket-visual::after {
            content: '';
            position: absolute;
            top: 0; left: 0; right: 0; bottom: 0;
            background: linear-gradient(to right, rgba(0,0,0,0.4), rgba(0,0,0,0.1));
            z-index: 1;
        }

        .ticket-poster {
            width: 100%;
            height: 100%;
            object-fit: cover;
            opacity: 0.8;
            filter: grayscale(20%);
        }

        .ticket-body {
            flex-grow: 1;
            padding: 35px;
            display: flex;
            flex-direction: column;
        }

        .ticket-badge {
            display: inline-block;
            padding: 4px 12px;
            background: var(--netflix-red);
            color: white;
            font-weight: 800;
            font-size: 0.7rem;
            text-transform: uppercase;
            border-radius: 4px;
            margin-bottom: 15px;
            letter-spacing: 1px;
        }

        .ticket-movie-title {
            font-family: 'Outfit', sans-serif;
            font-weight: 900;
            font-size: 2.2rem;
            line-height: 1.1;
            margin-bottom: 25px;
            color: #000;
            text-transform: uppercase;
        }

        .info-grid {
            display: grid;
            grid-template-columns: repeat(2, 1fr);
            gap: 25px;
            margin-top: auto;
        }

        .info-item label {
            display: block;
            font-size: 0.75rem;
            color: var(--ticket-accent);
            text-transform: uppercase;
            letter-spacing: 1px;
            margin-bottom: 4px;
            font-weight: 600;
        }

        .info-item span {
            font-weight: 700;
            font-size: 1.1rem;
            color: #000;
        }

        .ticket-perforation {
            height: 2px;
            background-image: linear-gradient(to right, #ccc 50%, rgba(255,255,255,0) 0%);
            background-position: bottom;
            background-size: 15px 2px;
            background-repeat: repeat-x;
            margin: 0 40px;
            position: relative;
        }

        .ticket-perforation::before, .ticket-perforation::after {
            content: '';
            position: absolute;
            width: 30px;
            height: 30px;
            background-color: #f0f0f0;
            border-radius: 50%;
            top: -15px;
            z-index: 2;
        }

        .ticket-perforation::before { left: -55px; }
        .ticket-perforation::after { right: -55px; }

        @@media print {
            .ticket-perforation::before, .ticket-perforation::after {
                background-color: white !important;
                border: 1px solid #ddd;
            }
        }

        .ticket-stub-new {
            padding: 25px 40px;
            background-color: #fafafa;
            display: flex;
            justify-content: space-between;
            align-items: center;
        }

        .stub-info h4 {
            font-weight: 800;
            font-size: 1.1rem;
            margin-bottom: 5px;
            color: #333;
        }

        .stub-qr {
            width: 100px;
            height: 100px;
            background: white;
            padding: 5px;
            border: 1px solid #eee;
        }

        .print-actions {
            background: white;
            padding: 15px 25px;
            border-radius: 12px;
            box-shadow: 0 4px 15px rgba(0,0,0,0.05);
            display: flex;
            gap: 15px;
            border: 1px solid rgba(0,0,0,0.05);
        }
    </style>
</head>
<body>
    <div class="container-fluid p-0">
        <main role="main">
            @RenderBody()
        </main>
    </div>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
 
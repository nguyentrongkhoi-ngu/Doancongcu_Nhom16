@model CinemaBooking.Models.ViewModels.PhimDanhGiaViewModel

<div class="glass-panel p-4 mb-4 border-0">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h4 class="text-white fw-bold mb-0">Đánh giá & Nhận xét</h4>
        <a asp-controller="DanhGia" asp-action="DanhSachDanhGia" asp-route-id="@Model.Phim.MaPhim" 
           class="btn btn-netflix-gray btn-sm">Xem tất cả</a>
    </div>

    <div class="row align-items-center mb-5 g-4">
        <div class="col-md-auto text-center border-md-end border-secondary border-opacity-25 pe-md-5">
            <div class="display-3 text-white fw-bold">@Model.DiemTrungBinh</div>
            <div class="stars-container mb-2 fs-5">
                @for (int i = 1; i <= 5; i++)
                {
                    if (i <= Math.Floor(Model.DiemTrungBinh))
                    {
                        <i class="fas fa-star text-netflix"></i>
                    }
                    else if (i - 0.5 <= Model.DiemTrungBinh)
                    {
                        <i class="fas fa-star-half-alt text-netflix"></i>
                    }
                    else
                    {
                        <i class="far fa-star text-white-50"></i>
                    }
                }
            </div>
            <div class="text-white-50 small">từ @Model.TongSoDanhGia lượt đánh giá</div>
        </div>
        
        <div class="col-md text-center text-md-start ps-md-5">
            <h5 class="text-white mb-3">Bạn đã xem phim này?</h5>
            <p class="text-white-50 small mb-4">Hãy chia sẻ cảm nhận của bạn để cộng đồng CineZore cùng thảo luận nhé!</p>
            <a asp-controller="DanhGia" asp-action="CreateDanhGia" asp-route-id="@Model.Phim.MaPhim" 
               class="btn btn-netflix btn-sm px-4 py-2">
                <i class="fas fa-pen-nib me-2"></i>Viết đánh giá của bạn
            </a>
        </div>
    </div>

    @if (Model.DanhSachDanhGia.Any())
    {
        <h6 class="text-white fw-bold mb-4 opacity-75">Bình luận mới nhất</h6>
        
        <div class="d-flex flex-column gap-3">
            @foreach (var danhGia in Model.DanhSachDanhGia.Take(3))
            {
                <div class="review-item p-3 border-bottom border-secondary border-opacity-10">
                    <div class="d-flex justify-content-between align-items-start mb-2">
                        <div class="d-flex align-items-center">
                            <div class="avatar-circle me-3" style="width: 36px; height: 36px; font-size: 0.9rem; background: rgba(255,255,255,0.1);">
                                @danhGia.NguoiDung.HoTen?.Substring(0, 1).ToUpper()
                            </div>
                            <div>
                                <h6 class="text-white mb-0 small fw-bold">@danhGia.NguoiDung.HoTen</h6>
                                <span class="text-white-50 x-small">@danhGia.NgayDanhGia?.ToString("dd/MM/yyyy")</span>
                            </div>
                        </div>
                        <div class="stars-container x-small">
                            @for (int i = 1; i <= 5; i++)
                            {
                                if (i <= danhGia.DiemSo)
                                {
                                    <i class="fas fa-star text-netflix"></i>
                                }
                                else
                                {
                                    <i class="far fa-star text-white-50"></i>
                                }
                            }
                        </div>
                    </div>
                    <p class="text-white-50 small mb-0 ps-5 mt-1">@danhGia.BinhLuan</p>
                </div>
            }
        </div>
    }
    else
    {
        <div class="alert bg-white bg-opacity-5 text-white-50 border-0 text-center py-4 rounded-4">
            <i class="far fa-comment-dots fs-3 mb-2 d-block"></i>
            Chưa có đánh giá nào cho phim này.
        </div>
    }
</div>
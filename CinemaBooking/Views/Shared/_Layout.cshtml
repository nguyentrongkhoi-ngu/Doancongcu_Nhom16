<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - CineZore 2026</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;500;600;700;900&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/swiper@11/swiper-bundle.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/home-cinezore.css" asp-append-version="true" />
    <style>
        :root {
            --netflix-red: #E50914;
            --netflix-dark: #141414;
            --glass-bg: rgba(20, 20, 20, 0.7);
            --glass-border: rgba(255, 255, 255, 0.1);
        }

        body {
            background-color: var(--netflix-dark);
            color: #fff;
            font-family: 'Segoe UI', Roboto, Helvetica, Arial, sans-serif;
            overflow-x: hidden;
        }

        /* Immersive Navbar Styling */
        .navbar-custom {
            background: rgba(10, 10, 10, 0); /* Start transparent */
            backdrop-filter: blur(0px);
            -webkit-backdrop-filter: blur(0px);
            border-bottom: 1px solid rgba(255, 255, 255, 0);
            padding: 1.5rem 2rem;
            transition: all 0.4s cubic-bezier(0.165, 0.84, 0.44, 1);
            z-index: 1000;
            position: fixed;
            top: 0;
            width: 100%;
        }

        .navbar-custom.scrolled {
            background: rgba(15, 15, 15, 0.85) !important;
            backdrop-filter: blur(25px) !important;
            -webkit-backdrop-filter: blur(25px) !important;
            padding: 0.8rem 2rem !important;
            border-bottom: 1px solid rgba(255, 255, 255, 0.1) !important;
            box-shadow: 0 4px 30px rgba(0, 0, 0, 0.3);
        }

        .bg-netflix { background-color: var(--netflix-red); }
        .text-netflix { color: var(--netflix-red); }

        footer {
            background: #000;
            padding: 4rem 0 2rem;
            margin-top: 5rem;
            border-top: 1px solid var(--glass-border);
        }

        /* --- SHARP & CLEAR OVERRIDE --- */
        .navbar-custom .nav-link-cz, 
        .navbar-custom .navbar-logo-text,
        .dropdown-menu-cz .dropdown-item-cz {
            color: #f8f9fa !important;
            opacity: 1 !important;
            font-weight: 600 !important;
            text-shadow: none !important;
        }
        
        .dropdown-menu-cz {
            background: rgba(35, 35, 35, 0.98) !important;
            border: 1px solid rgba(255, 255, 255, 0.25) !important;
        }

        .dropdown-item-cz:hover {
            background: rgba(229, 9, 20, 0.2) !important;
            color: #FFFFFF !important;
        }

        .text-white-50 {
            color: rgba(255, 255, 255, 0.85) !important;
        }

        /* --- REAL-TIME SEARCH STYLES --- */
        .header-search-wrapper { position: relative; }
        
        .search-results-dropdown {
            position: absolute;
            top: calc(100% + 15px);
            left: 0;
            width: 380px;
            background: rgba(30, 30, 30, 0.9);
            backdrop-filter: blur(20px);
            -webkit-backdrop-filter: blur(20px);
            border: 1px solid rgba(255, 255, 255, 0.1);
            border-radius: 12px;
            box-shadow: 0 15px 35px rgba(0,0,0,0.5);
            z-index: 2000;
            overflow: hidden;
            transform-origin: top center;
            animation: searchFadeIn 0.3s cubic-bezier(0.165, 0.84, 0.44, 1);
        }

        @keyframes searchFadeIn {
            from { opacity: 0; transform: translateY(-10px) scale(0.98); }
            to { opacity: 1; transform: translateY(0) scale(1); }
        }

        .search-suggestion-item {
            display: flex;
            padding: 12px 15px;
            gap: 15px;
            cursor: pointer;
            transition: all 0.2s ease;
            border-bottom: 1px solid rgba(255, 255, 255, 0.05);
        }

        .search-suggestion-item:last-child { border-bottom: none; }
        
        .search-suggestion-item:hover {
            background: rgba(229, 9, 20, 0.15);
            padding-left: 20px;
        }

        .suggestion-poster {
            width: 50px;
            height: 75px;
            flex-shrink: 0;
            border-radius: 4px;
            overflow: hidden;
            box-shadow: 0 4px 8px rgba(0,0,0,0.3);
        }

        .suggestion-poster img {
            width: 100%;
            height: 100%;
            object-fit: cover;
        }

        .suggestion-info {
            display: flex;
            flex-direction: column;
            justify-content: center;
            overflow: hidden;
        }

        .suggestion-title {
            margin: 0 0 5px 0;
            font-size: 0.95rem;
            font-weight: 700;
            color: #fff;
            white-space: nowrap;
            overflow: hidden;
            text-overflow: ellipsis;
        }

        .suggestion-meta {
            font-size: 0.8rem;
            color: rgba(255, 255, 255, 0.6);
            display: flex;
            align-items: center;
            gap: 8px;
        }

        .no-suggestions {
            padding: 20px;
            text-align: center;
            color: rgba(255, 255, 255, 0.5);
            font-size: 0.9rem;
        }
        /* --- PREMIUM HEADER BUTTONS --- */
        .btn-nav-login {
            color: #fff;
            font-weight: 700;
            text-decoration: none;
            padding: 0.6rem 1.4rem;
            border-radius: 8px;
            transition: all 0.3s ease;
            font-size: 0.9rem;
        }
        
        .btn-nav-login:hover { color: var(--netflix-red); }

        .btn-nav-register {
            background: linear-gradient(135deg, #E50914 0%, #B20710 100%);
            color: #fff;
            font-weight: 700;
            text-decoration: none;
            padding: 0.6rem 1.6rem;
            border-radius: 10px;
            box-shadow: 0 4px 15px rgba(229, 9, 20, 0.3);
            transition: all 0.3s cubic-bezier(0.165, 0.84, 0.44, 1);
            font-size: 0.9rem;
            border: 1px solid rgba(255, 255, 255, 0.1);
        }

        .btn-nav-register:hover {
            transform: translateY(-2px);
            box-shadow: 0 8px 25px rgba(229, 9, 20, 0.5);
            color: #fff;
            filter: brightness(1.1);
        }

        .user-avatar-nav {
            width: 36px;
            height: 36px;
            border-radius: 50%;
            border: 2px solid rgba(255, 255, 255, 0.2);
            transition: all 0.3s ease;
            object-fit: cover;
        }

        .user-avatar-placeholder {
            width: 36px;
            height: 36px;
            border-radius: 50%;
            background: linear-gradient(135deg, #444 0%, #222 100%);
            display: flex;
            align-items: center;
            justify-content: center;
            font-weight: 700;
            color: #fff;
            border: 2px solid rgba(255, 255, 255, 0.1);
        }

        .search-clear-btn {
            position: absolute;
            right: 40px;
            top: 50%;
            transform: translateY(-50%);
            background: none;
            border: none;
            color: rgba(255, 255, 255, 0.5);
            font-size: 0.8rem;
            cursor: pointer;
            z-index: 5;
            transition: color 0.2s;
        }
        
        .search-clear-btn:hover { color: #fff; }

        /* Mobile Adjustments */
        @media (max-width: 991.98px) {
            .navbar-custom { padding: 1rem; background: rgba(10,10,10,0.95) !important; backdrop-filter: blur(20px); }
            .navbar-collapse { margin-top: 1.5rem; background: rgba(20,20,20,0.98); padding: 2rem; border-radius: 20px; border: 1px solid rgba(255,255,255,0.1); }
            .user-action-group { flex-direction: column; align-items: flex-start; gap: 1.5rem; margin-top: 2rem; }
        }
    </style>
    @await RenderSectionAsync("Styles", required: false)
</head>
    @{
        var title = ViewData["Title"]?.ToString() ?? "";
        var bodyClass = "";
        
        if (title == "Trang chủ") {
            bodyClass = "home-page";
        } else if (title == "Danh Sách Phim" || title == "Phim Đang Chiếu" || title == "Lịch Chiếu Phim" || title.Contains("Thanh toán") || title.Contains("Chi tiết phim") || title.Contains("Chọn ghế")) {
            bodyClass = "immersive-page";
        }
    }
<body class="@bodyClass">
    <nav class="navbar navbar-expand-lg navbar-custom sticky-top">
        <div class="container-fluid px-lg-5">
            <!-- Brand Logo -->
            <a class="navbar-logo-group" asp-area="" asp-controller="Home" asp-action="Index">
                <div class="navbar-logo-icon">C</div>
                <span class="navbar-logo-text">CINEZORE</span>
            </a>

            <!-- Mobile Toggle -->
            <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarMain">
                <span class="navbar-toggler-icon"></span>
            </button>

            <!-- Navigation Links -->
            <div class="collapse navbar-collapse" id="navbarMain">
                <ul class="navbar-nav mx-auto mb-2 mb-lg-0 gap-lg-2">
                    <li class="nav-item">
                        <a class="nav-link-cz @(ViewData["Title"]?.ToString() == "Trang chủ" ? "active" : "")" asp-controller="Home" asp-action="Index">Trang chủ</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link-cz" asp-controller="Phim" asp-action="Index">Phim đang chiếu</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link-cz" asp-controller="RapPhim" asp-action="Index">Rạp chiếu</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link-cz" asp-controller="Home" asp-action="Index" fragment="promotions">Khuyến mãi</a>
                    </li>
                </ul>
                
                <!-- Right Side Actions -->
                <div class="user-action-group">
                    <!-- Search Bar -->
                    <div class="header-search-container d-none d-xl-block">
                        <div class="header-search-wrapper">
                            <i class="fas fa-search header-search-icon"></i>
                            <input type="text" class="header-search-input" placeholder="Tìm kiếm phim...">
                            <button class="search-clear-btn" style="display: none;"><i class="fas fa-times"></i></button>
                            <div id="search-results-container" class="search-results-dropdown" style="display: none;"></div>
                        </div>
                    </div>

                    @if (User.Identity.IsAuthenticated)
                    {
                        var userIdInt = await CinemaBooking.Extensions.UserExtensions.GetLegacyUserIdAsync(User, _layoutDbContext);
                        NguoiDung dbUser = null;
                        if (userIdInt.HasValue)
                        {
                            dbUser = await _layoutDbContext.NguoiDungs.FindAsync(userIdInt.Value);
                        }
                        var fullName = dbUser?.HoTen ?? User.Identity.Name ?? "Người dùng";
                        var avatarUrl = dbUser?.AvatarUrl;

                        <div class="dropdown user-dropdown">
                            <a class="dropdown-toggle d-flex align-items-center gap-2 text-decoration-none" href="#" role="button" data-bs-toggle="dropdown" aria-expanded="false">
                                @if (!string.IsNullOrEmpty(avatarUrl))
                                {
                                    <img src="@avatarUrl" class="user-avatar-nav" alt="Avatar">
                                }
                                else
                                {
                                    <div class="user-avatar-placeholder">@fullName.Substring(0, 1).ToUpper()</div>
                                }
                                <span class="text-white d-none d-md-inline ms-1 small fw-800">@fullName</span>
                            </a>
                            <ul class="dropdown-menu dropdown-menu-cz dropdown-menu-end shadow-lg border-0">
                                <li class="px-3 py-2 small text-white-50">Chào mừng, @fullName</li>
                                <li><hr class="dropdown-divider opacity-10"></li>
                                @if (User.IsInRole("Admin"))
                                {
                                    <li><a class="dropdown-item dropdown-item-cz text-warning" asp-area="Admin" asp-controller="Home" asp-action="Index"><i class="fas fa-chart-line"></i> Quản trị hệ thống</a></li>
                                }
                                else
                                {
                                    <li><a class="dropdown-item dropdown-item-cz" asp-controller="UserProfile" asp-action="Index"><i class="fas fa-user-circle"></i> Hồ sơ cá nhân</a></li>
                                    <li><a class="dropdown-item dropdown-item-cz" asp-controller="Home" asp-action="LichSuDatVe"><i class="fas fa-ticket-alt"></i> Vé đã đặt</a></li>
                                }
                                <li><hr class="dropdown-divider opacity-10"></li>
                                <li><a class="dropdown-item dropdown-item-cz" asp-controller="Account" asp-action="Logout"><i class="fas fa-sign-out-alt"></i> Đăng xuất</a></li>
                            </ul>
                        </div>
                    }
                    else
                    {
                        <div class="d-flex align-items-center gap-4">
                            <a class="btn-nav-login" asp-controller="Account" asp-action="Login">Đăng nhập</a>
                            <a class="btn-nav-register" asp-controller="Account" asp-action="Register">Đăng ký</a>
                        </div>
                    }
                </div>
            </div>
        </div>
    </nav>

    <main role="main">
        @RenderBody()
    </main>

    <footer class="footer-cz">
        <div class="container-fluid px-lg-5">
            <div class="row g-4 footer-top">
                <!-- Column 1: Brand & Bio -->
                <div class="col-lg-4 col-md-12 pe-lg-5">
                    <a class="navbar-logo-group mb-4" asp-controller="Home" asp-action="Index">
                        <div class="navbar-logo-icon">C</div>
                        <span class="navbar-logo-text">CINEZORE</span>
                    </a>
                    <p class="footer-bio mb-4 opacity-75">
                        Trải nghiệm điện ảnh đỉnh cao với CineZore. Chúng tôi mang đến hệ thống âm thanh, hình ảnh chuẩn quốc tế cùng dịch vụ đặt vé trực tuyến êm ái nhất cho bạn.
                    </p>
                    <div class="social-group">
                        <a href="#" class="social-link"><i class="fab fa-facebook-f"></i></a>
                        <a href="#" class="social-link"><i class="fab fa-instagram"></i></a>
                        <a href="#" class="social-link"><i class="fab fa-youtube"></i></a>
                        <a href="#" class="social-link"><i class="fab fa-tiktok"></i></a>
                    </div>
                </div>

                <!-- Column 2: Explore -->
                <div class="col-lg-3 col-md-4 col-6">
                    <h5 class="footer-title">Khám Phá</h5>
                    <ul class="footer-links-list">
                        <li><a asp-controller="Home" asp-action="Index">Trang chủ</a></li>
                        <li><a asp-controller="Phim" asp-action="Index">Phim đang chiếu</a></li>
                        <li><a href="#cinemas">Rạp chiếu phim</a></li>
                        <li><a href="#promotions">Khuyến mãi</a></li>
                        <li><a asp-controller="Home" asp-action="LichSuDatVe">Lịch sử đặt vé</a></li>
                    </ul>
                </div>

                <!-- Column 3: Rules -->
                <div class="col-lg-2 col-md-4 col-6">
                    <h5 class="footer-title">Hỗ Trợ</h5>
                    <ul class="footer-links-list">
                        <li><a href="#">Quy định chung</a></li>
                        <li><a href="#">Điều khoản sử dụng</a></li>
                        <li><a href="#">Chính sách bảo mật</a></li>
                        <li><a href="#">Câu hỏi thường gặp</a></li>
                        <li><a href="#">Liên hệ với chúng tôi</a></li>
                    </ul>
                </div>

                <!-- Column 4: Contact & App -->
                <div class="col-lg-3 col-md-4">
                    <h5 class="footer-title">Liên Hệ</h5>
                    <div class="contact-item mb-3">
                        <div class="contact-icon"><i class="fas fa-phone-alt"></i></div>
                        <div class="contact-info">
                            <span class="label">Hotline 24/7</span>
                            <span class="value">1900 1234</span>
                        </div>
                    </div>
                    <div class="contact-item mb-3">
                        <div class="contact-icon"><i class="fas fa-envelope"></i></div>
                        <div class="contact-info">
                            <span class="label">Email</span>
                            <span class="value">support@cinezore.vn</span>
                        </div>
                    </div>
                    <div class="app-badges mt-4">
                        <p class="small text-white-50 mb-3">Tải ứng dụng CineZore Mobile</p>
                        <div class="d-flex gap-2">
                            <a href="#" class="app-btn"><i class="fab fa-apple"></i> App Store</a>
                            <a href="#" class="app-btn"><i class="fab fa-google-play"></i> Google Play</a>
                        </div>
                    </div>
                </div>
            </div>

            <hr class="footer-divider">

            <div class="footer-bottom d-flex flex-column flex-md-row justify-content-between align-items-center py-4">
                <p class="copyright-text mb-md-0">
                    &copy; 2026 CineZore Entertainment. All rights reserved.
                </p>
                <div class="footer-brand-meta d-flex gap-4">
                    <a href="#" class="small opacity-50 hover-white">Điều khoản</a>
                    <a href="#" class="small opacity-50 hover-white">Bảo mật</a>
                    <a href="#" class="small opacity-50 hover-white">Cookies</a>
                </div>
            </div>
        </div>
    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/swiper@11/swiper-bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    <script>
        // Immersive Navbar Interactions
        (function() {
            const nav = document.querySelector('.navbar-custom');
            if (!nav) return;

            const updateNavbar = () => {
                if (window.scrollY > 30) {
                    nav.classList.add('scrolled');
                } else {
                    nav.classList.remove('scrolled');
                }
            };

            window.addEventListener('scroll', updateNavbar, { passive: true });
            updateNavbar(); // Initial check

            // Active Link Highlighting with Fragment Support
            const currentPath = window.location.pathname;
            const currentHash = window.location.hash;
            const navLinks = document.querySelectorAll('.nav-link-cz');
            
            navLinks.forEach(link => {
                const linkHref = link.getAttribute('href') || '';
                const linkPath = linkHref.split('#')[0];
                const linkHash = linkHref.includes('#') ? '#' + linkHref.split('#')[1] : '';
                
                const isHome = currentPath === '/' || currentPath === '/Home/Index';
                const isLinkHome = linkPath === '/' || linkPath === '/Home/Index';
                
                if (isLinkHome && isHome) {
                    if (!linkHash || linkHash === currentHash) {
                        link.classList.add('active');
                    } else {
                        link.classList.remove('active');
                    }
                } else if (linkPath === currentPath && !isHome) {
                    link.classList.add('active');
                } else {
                    link.classList.remove('active');
                }

                // Handle smooth scroll for fragment links on same page
                if (linkHash && isHome && isLinkHome) {
                    link.addEventListener('click', (e) => {
                        const target = document.querySelector(linkHash);
                        if (target) {
                            e.preventDefault();
                            const offset = 100;
                            const targetPosition = target.getBoundingClientRect().top + window.pageYOffset - offset;
                            window.scrollTo({ top: targetPosition, behavior: 'smooth' });
                            window.history.pushState(null, null, linkHash);
                            
                            // Update active state manually
                            navLinks.forEach(l => l.classList.remove('active'));
                            link.classList.add('active');
                        }
                    });
                }
            });

            // Search Bar Interaction
            const searchInput = document.querySelector('.header-search-input');
            const searchIcon = document.querySelector('.header-search-icon');
            
            if (searchInput) {
                const resultsContainer = document.getElementById('search-results-container');
                const clearBtn = document.querySelector('.search-clear-btn');
                let debounceTimer;

                const performSearch = () => {
                    const query = searchInput.value;
                    if (query.trim()) {
                         window.location.href = `/Phim/Index?searchString=${encodeURIComponent(query)}`;
                    }
                };

                const updateClearBtn = () => {
                    if (clearBtn) clearBtn.style.display = searchInput.value ? 'block' : 'none';
                };
                
                const fetchSuggestions = (query) => {
                    if (query.length < 2) {
                        resultsContainer.style.display = 'none';
                        resultsContainer.innerHTML = '';
                        return;
                    }

                    fetch(`/Phim/SearchSuggest?query=${encodeURIComponent(query)}`)
                        .then(response => response.text())
                        .then(html => {
                            if (html.trim()) {
                                resultsContainer.innerHTML = html;
                                resultsContainer.style.display = 'block';
                            } else {
                                resultsContainer.style.display = 'none';
                            }
                        })
                        .catch(err => console.error('Search error:', err));
                };

                searchInput.addEventListener('input', function() {
                    clearTimeout(debounceTimer);
                    const query = this.value;
                    updateClearBtn();
                    debounceTimer = setTimeout(() => fetchSuggestions(query), 300);
                });

                if (clearBtn) {
                    clearBtn.addEventListener('click', () => {
                        searchInput.value = '';
                        updateClearBtn();
                        resultsContainer.style.display = 'none';
                        searchInput.focus();
                    });
                }

                searchInput.addEventListener('keypress', function(e) {
                    if (e.key === 'Enter') {
                        performSearch();
                    }
                });

                // Hide results when clicking outside
                document.addEventListener('click', function(e) {
                    if (!searchInput.contains(e.target) && !resultsContainer.contains(e.target)) {
                        resultsContainer.style.display = 'none';
                    }
                });

                // Show results again when refocusing
                searchInput.addEventListener('focus', function() {
                    if (this.value.length >= 2 && resultsContainer.innerHTML.trim()) {
                        resultsContainer.style.display = 'block';
                    }
                });
                
                if (searchIcon) {
                    searchIcon.addEventListener('click', performSearch);
                    searchIcon.style.cursor = 'pointer';
                }
            }
        })();
    </script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>

<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - CineZore 2026</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;500;600;700;900&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/home-cinezore.css" asp-append-version="true" />
    <style>
        :root {
            --netflix-red: #E50914;
            --netflix-dark: #141414;
            --glass-bg: rgba(20, 20, 20, 0.7);
            --glass-border: rgba(255, 255, 255, 0.1);
        }

        body {
            background-color: var(--netflix-dark);
            color: #fff;
            font-family: 'Segoe UI', Roboto, Helvetica, Arial, sans-serif;
            overflow-x: hidden;
        }

        /* Glassmorphism Navbar */
        .navbar-custom {
            background: var(--glass-bg);
            backdrop-filter: blur(20px);
            -webkit-backdrop-filter: blur(20px);
            border-bottom: 1px solid var(--glass-border);
            padding: 1rem 2rem;
            transition: all 0.3s ease;
            z-index: 1000;
        }

        .navbar-brand {
            font-weight: 800;
            color: var(--netflix-red) !important;
            font-size: 1.8rem;
            letter-spacing: -1px;
            text-transform: uppercase;
        }

        .nav-link {
            color: #e5e5e5 !important;
            font-weight: 500;
            padding: 0.5rem 1rem !important;
            transition: color 0.3s ease;
        }

        .nav-link:hover {
            color: #fff !important;
        }

        /* User Avatar Dropdown */
        .user-dropdown .dropdown-toggle::after {
            display: none;
        }

        .user-avatar-nav {
            width: 36px;
            height: 36px;
            border-radius: 8px;
            object-fit: cover;
            border: 2px solid var(--glass-border);
            transition: transform 0.2s ease;
        }

        .user-avatar-placeholder {
            width: 36px;
            height: 36px;
            border-radius: 8px;
            background: var(--netflix-red);
            color: #fff;
            display: flex;
            align-items: center;
            justify-content: center;
            font-weight: bold;
            font-size: 0.9rem;
            border: 2px solid var(--glass-border);
        }

        .dropdown-menu-dark {
            background: rgba(30, 30, 30, 0.95);
            backdrop-filter: blur(10px);
            border: 1px solid var(--glass-border);
            border-radius: 12px;
            box-shadow: 0 10px 30px rgba(0,0,0,0.5);
            margin-top: 15px !important;
            padding: 10px;
        }

        .dropdown-item {
            border-radius: 8px;
            padding: 10px 15px;
            color: #e5e5e5;
            transition: all 0.2s ease;
        }

        .dropdown-item:hover {
            background: var(--netflix-red);
            color: #fff;
        }

        .dropdown-divider {
            border-top: 1px solid var(--glass-border);
        }

        .bg-netflix { background-color: var(--netflix-red); }
        .text-netflix { color: var(--netflix-red); }

        footer {
            background: #000;
            padding: 4rem 0 2rem;
            margin-top: 5rem;
            border-top: 1px solid var(--glass-border);
        }
    </style>
    @await RenderSectionAsync("Styles", required: false)
</head>
<body>
    <nav class="navbar navbar-expand-lg navbar-custom sticky-top">
        <div class="container-fluid">
            <a class="navbar-brand" asp-area="" asp-controller="Home" asp-action="Index">CINEZORE</a>
            <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarMain">
                <span class="navbar-toggler-icon"></span>
            </button>
            <div class="collapse navbar-collapse" id="navbarMain">
                <ul class="navbar-nav me-auto mb-2 mb-lg-0">
                    <li class="nav-item"><a class="nav-link" asp-controller="Home" asp-action="Index">Trang chủ</a></li>
                    <li class="nav-item"><a class="nav-link" asp-controller="Phim" asp-action="Index">Phim đang chiếu</a></li>
                    <li class="nav-item"><a class="nav-link" href="/Search/MoviesByDate">Lịch chiếu</a></li>
                </ul>
                
                <div class="d-flex align-items-center gap-3">
                    @if (User.Identity.IsAuthenticated)
                    {
                        var userIdInt = await CinemaBooking.Extensions.UserExtensions.GetLegacyUserIdAsync(User, _layoutDbContext);
                        NguoiDung dbUser = null;
                        if (userIdInt.HasValue)
                        {
                            dbUser = await _layoutDbContext.NguoiDungs.FindAsync(userIdInt.Value);
                        }
                        var fullName = dbUser?.HoTen ?? User.Identity.Name ?? "Người dùng";
                        var avatarUrl = dbUser?.AvatarUrl;

                        <div class="dropdown user-dropdown">
                            <a class="dropdown-toggle d-flex align-items-center gap-2 text-decoration-none" href="#" role="button" data-bs-toggle="dropdown" aria-expanded="false">
                                @if (!string.IsNullOrEmpty(avatarUrl))
                                {
                                    <img src="@avatarUrl" class="user-avatar-nav" alt="Avatar">
                                }
                                else
                                {
                                    <div class="user-avatar-placeholder">@fullName.Substring(0, 1).ToUpper()</div>
                                }
                                <span class="text-white d-none d-md-inline small fw-bold">@fullName</span>
                            </a>
                            <ul class="dropdown-menu dropdown-menu-dark dropdown-menu-end shadow-lg">
                                <li class="px-3 py-2 small text-white-50">Chào, @fullName</li>
                                <li><hr class="dropdown-divider"></li>
                                <li><a class="dropdown-item" asp-controller="UserProfile" asp-action="Index"><i class="bi bi-person-badge me-2"></i>Hồ sơ cá nhân</a></li>
                                <li><a class="dropdown-item" asp-controller="Home" asp-action="LichSuDatVe"><i class="bi bi-ticket-perforated me-2"></i>Vé đã đặt</a></li>
                                <li><a class="dropdown-item" asp-controller="UserProfile" asp-action="ChangePassword"><i class="bi bi-shield-lock me-2"></i>Đổi mật khẩu</a></li>
                                <li><hr class="dropdown-divider"></li>
                                <li><a class="dropdown-item text-netflix" asp-controller="Account" asp-action="Logout"><i class="bi bi-box-arrow-right me-2"></i>Đăng xuất</a></li>
                            </ul>
                        </div>
                    }
                    else
                    {
                        <a class="btn btn-netflix btn-sm px-4 fw-bold rounded-pill" asp-controller="Account" asp-action="Login">Đăng nhập</a>
                    }
                </div>
            </div>
        </div>
    </nav>

    <main role="main">
        @RenderBody()
    </main>

    <footer>
        <div class="container text-center">
            <p class="text-white-50">&copy; 2026 CineZore Entertainment. All rights reserved.</p>
            <div class="d-flex justify-content-center gap-4 mt-3">
                <a href="#" class="text-white-50"><i class="fab fa-facebook"></i></a>
                <a href="#" class="text-white-50"><i class="fab fa-instagram"></i></a>
                <a href="#" class="text-white-50"><i class="fab fa-youtube"></i></a>
            </div>
        </div>
    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    <script>
        // Navbar scroll transparency effect
        (function() {
            const nav = document.querySelector('.navbar-custom');
            if (!nav) return;
            const onScroll = function() {
                if (window.scrollY > 60) {
                    nav.classList.add('scrolled');
                } else {
                    nav.classList.remove('scrolled');
                }
            };
            window.addEventListener('scroll', onScroll, { passive: true });
            onScroll();
        })();
    </script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>

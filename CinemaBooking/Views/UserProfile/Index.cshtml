@model CinemaBooking.Models.NguoiDung

@{
    ViewData["Title"] = "Trung tâm Tài khoản - CineZore 2026";
    var totalSpent = ViewBag.TotalSpent ?? 0m;
    var totalTickets = ViewBag.TotalTickets ?? 0;
    var memberRank = ViewBag.MemberRank ?? "Đồng";
    var discountPercent = ViewBag.DiscountPercent ?? 0m;
    
    // Define rank colors/gradients
    string rankGradient = "linear-gradient(135deg, #a8a8a8 0%, #707070 100%)"; // Đồng
    string nextRank = "Bạc";
    decimal nextThreshold = 1000000;
    
    if (memberRank == "Bạc") {
        rankGradient = "linear-gradient(135deg, #e3e3e3 0%, #a1a1a1 100%)";
        nextRank = "Vàng";
        nextThreshold = 5000000;
    } else if (memberRank == "Vàng") {
        rankGradient = "linear-gradient(135deg, #ffe08a 0%, #d4af37 100%)";
        nextRank = "Kim Cương";
        nextThreshold = 10000000;
    } else if (memberRank == "Kim Cương") {
        rankGradient = "linear-gradient(135deg, #b9f2ff 0%, #00d4ff 100%)";
        nextRank = "";
        nextThreshold = 0;
    }

    decimal progressPercent = nextThreshold > 0 ? (totalSpent / nextThreshold) * 100 : 100;
    if (progressPercent > 100) progressPercent = 100;
}

<div class="container-fluid px-4" style="padding-top: 100px; min-height: 90vh; background: radial-gradient(circle at 10% 20%, rgba(229, 9, 20, 0.05) 0%, transparent 40%);">
    <div class="row g-4">
        <!-- Sidebar Navigation (Glass Design) -->
        <div class="col-xl-3 col-lg-4">
            <div class="glass-container sticky-top" style="top: 100px; z-index: 10;">
                <div class="text-center p-4">
                    <div class="profile-avatar-wrapper mb-3">
                        @if (!string.IsNullOrEmpty(Model.AvatarUrl))
                        {
                            <img src="@Model.AvatarUrl" class="profile-avatar-img shadow-glow" alt="Avatar">
                        }
                        else
                        {
                            <div class="profile-avatar-placeholder shadow-glow">
                                @Model.HoTen?.Substring(0, 1).ToUpper()
                            </div>
                        }
                        <div class="rank-badge" style="background: @rankGradient;">@memberRank</div>
                    </div>
                    <h4 class="text-white fw-bold mb-0">@Model.HoTen</h4>
                    <p class="text-white-50 small mb-4">@@@Model.TenDangNhap</p>
                    
                    <div class="d-grid gap-2">
                        <a class="nav-link-btn active" asp-action="Index">
                            <i class="fas fa-th-large me-2"></i> Tổng quan
                        </a>
                        <a class="nav-link-btn" asp-action="Edit">
                            <i class="fas fa-user-edit me-2"></i> Chỉnh sửa hồ sơ
                        </a>
                        <a class="nav-link-btn" asp-action="ChangePassword">
                            <i class="fas fa-shield-alt me-2"></i> Bảo mật
                        </a>
                        <a class="nav-link-btn" asp-action="LichSuDatVe" asp-controller="Home">
                            <i class="fas fa-ticket-alt me-2"></i> Vé của tôi
                        </a>
                        <div class="nav-divider my-2"></div>
                        <a class="nav-link-btn text-danger" asp-action="Logout" asp-controller="Account">
                            <i class="fas fa-power-off me-2"></i> Đăng xuất
                        </a>
                    </div>
                </div>
            </div>
        </div>

        <!-- Main Dashboard -->
        <div class="col-xl-9 col-lg-8">
            <div class="row g-4">
                <!-- Digital Membership Card -->
                <div class="col-12">
                    <div class="membership-card" style="background: @rankGradient;">
                        <div class="card-glow"></div>
                        <div class="d-flex justify-content-between h-100 flex-column p-4">
                            <div class="d-flex justify-content-between align-items-start">
                                <div>
                                    <div class="card-label">THÀNH VIÊN CINEZORE</div>
                                    <div class="card-rank text-uppercase">@memberRank MEMBER</div>
                                </div>
                                <img src="/images/logo.png" alt="CineZore" style="height: 30px; filter: brightness(0) invert(1);">
                            </div>
                            <div class="mt-auto">
                                <div class="card-number">**** **** **** @(Model.MaNguoiDung.ToString().PadLeft(4, '0'))</div>
                                <div class="d-flex justify-content-between align-items-end">
                                    <div>
                                        <div class="card-label">CHỦ THẺ</div>
                                        <div class="card-holder">@Model.HoTen?.ToUpper()</div>
                                    </div>
                                    <div class="text-end">
                                        <div class="card-label">NGÀY THAM GIA</div>
                                        <div class="card-holder">@Model.NgayTao?.ToString("MM / yyyy")</div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Stats Grid -->
                <div class="col-md-4">
                    <div class="stat-card glass-container">
                        <div class="stat-icon bg-netflix-soft"><i class="fas fa-film"></i></div>
                        <div class="stat-content">
                            <div class="stat-value">@totalTickets</div>
                            <div class="stat-label">Vé đã đặt</div>
                        </div>
                    </div>
                </div>
                <div class="col-md-4">
                    <div class="stat-card glass-container">
                        <div class="stat-icon bg-info-soft"><i class="fas fa-wallet"></i></div>
                        <div class="stat-content">
                            <div class="stat-value">@string.Format("{0:N0}đ", totalSpent)</div>
                            <div class="stat-label">Tổng chi tiêu</div>
                        </div>
                    </div>
                </div>
                <div class="col-md-4">
                    <div class="stat-card glass-container">
                        <div class="stat-icon bg-warning-soft"><i class="fas fa-star"></i></div>
                        <div class="stat-content">
                            <div class="stat-value">@Model.DiemTichLuy</div>
                            <div class="stat-label">Điểm tích lũy</div>
                        </div>
                    </div>
                </div>

                <!-- Personal Info & QR Section -->
                <div class="col-lg-7">
                    <div class="glass-container p-4 h-100">
                        <div class="d-flex justify-content-between align-items-center mb-4">
                            <h5 class="text-white fw-bold mb-0"><i class="fas fa-info-circle me-2 text-netflix"></i>Thông tin chi tiết</h5>
                            <a asp-action="Edit" class="edit-link">Chỉnh sửa <i class="fas fa-chevron-right ms-1"></i></a>
                        </div>
                        <div class="info-list">
                            <div class="info-row">
                                <span class="label">Email</span>
                                <span class="value">@Model.Email</span>
                            </div>
                            <div class="info-row">
                                <span class="label">Số điện thoại</span>
                                <span class="value">@(Model.SoDienThoai ?? "Chưa cập nhật")</span>
                            </div>
                            <div class="info-row">
                                <span class="label">Tên đăng nhập</span>
                                <span class="value">@@@Model.TenDangNhap</span>
                            </div>
                            <div class="info-row">
                                <span class="label">Trạng thái</span>
                                <span class="value"><span class="status-dot"></span> Đang hoạt động</span>
                            </div>
                        </div>

                        @if (!string.IsNullOrEmpty(nextRank))
                        {
                            <div class="mt-4">
                                <div class="d-flex justify-content-between mb-2">
                                    <span class="text-white-50 small">Tiến trình lên hạng <strong>@nextRank</strong></span>
                                    <span class="text-white small">@string.Format("{0:N0}đ", totalSpent) / @string.Format("{0:N0}đ", nextThreshold)</span>
                                </div>
                                <div class="progress" style="height: 6px; background: rgba(255,255,255,0.05); border-radius: 3px;">
                                    <div class="progress-bar" role="progressbar" 
                                         style="width: @progressPercent%; background: @rankGradient; box-shadow: 0 0 10px rgba(255,255,255,0.2);" 
                                         aria-valuenow="@progressPercent" aria-valuemin="0" aria-valuemax="100"></div>
                                </div>
                                <p class="text-white-50 xs-small mt-2">Bạn cần chi tiêu thêm <strong>@string.Format("{0:N0}đ", nextThreshold - totalSpent)</strong> để nâng cấp hạng thành viên.</p>
                            </div>
                        }
                    </div>
                </div>

                <div class="col-lg-5">
                    <div class="glass-container p-4 h-100 text-center d-flex flex-column">
                        <h5 class="text-white fw-bold mb-3">Quyền Lợi Hiện Tại</h5>
                        <div class="benefit-box mb-3 flex-grow-1 d-flex flex-column justify-content-center">
                            <div class="display-4 fw-black text-white mb-0">@discountPercent%</div>
                            <div class="text-white-50 text-uppercase small letter-spacing-1">Giảm giá trực tiếp</div>
                            <p class="text-white-50 small mt-3 px-3">Hạng <strong>@memberRank</strong> được giảm <strong>@discountPercent%</strong> trên mỗi hóa đơn đặt vé phim.</p>
                        </div>
                        <div class="qr-label mt-auto">
                            <h6 class="text-white fw-bold mb-3">Mã Thành Viên QR</h6>
                            <div id="qrcode-wrapper" class="d-inline-block p-2 bg-white rounded-3 shadow-sm mb-2">
                                <div id="qrcode"></div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@section Styles {
    <style>
        :root {
            --glass-bg: rgba(255, 255, 255, 0.03);
            --glass-border: rgba(255, 255, 255, 0.08);
            --netflix-soft: rgba(229, 9, 20, 0.15);
            --info-soft: rgba(0, 212, 255, 0.15);
            --warning-soft: rgba(255, 215, 0, 0.15);
        }

        .glass-container {
            background: var(--glass-bg);
            backdrop-filter: blur(20px);
            border: 1px solid var(--glass-border);
            border-radius: 24px;
            transition: transform 0.3s ease, border-color 0.3s ease;
        }

        .profile-avatar-wrapper {
            position: relative;
            display: inline-block;
        }
        .profile-avatar-img, .profile-avatar-placeholder {
            width: 110px;
            height: 110px;
            border-radius: 35px;
            object-fit: cover;
            border: 3px solid var(--glass-border);
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 3rem;
            color: #fff;
            background: var(--netflix-red);
        }
        .shadow-glow {
            box-shadow: 0 10px 25px rgba(229, 9, 20, 0.3);
        }
        .rank-badge {
            position: absolute;
            bottom: -5px;
            right: -5px;
            padding: 4px 12px;
            border-radius: 12px;
            font-size: 0.7rem;
            font-weight: 800;
            color: #000;
            text-transform: uppercase;
            box-shadow: 0 4px 10px rgba(0,0,0,0.3);
            border: 2px solid rgba(255,255,255,0.2);
        }

        .nav-link-btn {
            display: flex;
            align-items: center;
            padding: 14px 20px;
            border-radius: 16px;
            color: rgba(255,255,255,0.6);
            text-decoration: none;
            transition: all 0.3s ease;
            font-weight: 500;
        }
        .nav-link-btn:hover {
            color: #fff;
            background: rgba(255,255,255,0.05);
        }
        .nav-link-btn.active {
            background: var(--netflix-soft);
            color: var(--netflix-red);
        }
        .nav-divider {
            height: 1px;
            background: var(--glass-border);
        }

        .membership-card {
            height: 240px;
            width: 100%;
            border-radius: 28px;
            position: relative;
            overflow: hidden;
            border: 1px solid rgba(255,255,255,0.2);
            box-shadow: 0 20px 40px rgba(0,0,0,0.4);
            color: #fff;
        }
        .card-glow {
            position: absolute;
            top: -50%;
            left: -50%;
            width: 200%;
            height: 200%;
            background: radial-gradient(circle at center, rgba(255,255,255,0.2) 0%, transparent 50%);
            pointer-events: none;
        }
        .card-label {
            font-size: 0.7rem;
            letter-spacing: 2px;
            opacity: 0.8;
            margin-bottom: 4px;
        }
        .card-rank {
            font-size: 1.8rem;
            font-weight: 900;
            letter-spacing: 1px;
            text-shadow: 0 2px 10px rgba(0,0,0,0.2);
        }
        .card-number {
            font-family: 'Courier New', Courier, monospace;
            font-size: 1.4rem;
            letter-spacing: 3px;
            margin-bottom: 20px;
        }
        .card-holder {
            font-weight: 700;
            letter-spacing: 1px;
        }

        .stat-card {
            padding: 24px;
            display: flex;
            align-items: center;
            gap: 20px;
        }
        .stat-icon {
            width: 56px;
            height: 56px;
            border-radius: 18px;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 1.4rem;
            color: #fff;
        }
        .stat-value {
            font-size: 1.4rem;
            font-weight: 800;
            color: #fff;
            line-height: 1.2;
        }
        .stat-label {
            font-size: 0.85rem;
            color: rgba(255,255,255,0.5);
            font-weight: 500;
        }

        .info-row {
            display: flex;
            justify-content: space-between;
            padding: 15px 0;
            border-bottom: 1px solid var(--glass-border);
        }
        .info-row:last-child {
            border-bottom: none;
        }
        .info-row .label {
            color: rgba(255,255,255,0.5);
            font-size: 0.9rem;
        }
        .info-row .value {
            color: #fff;
            font-weight: 600;
        }
        .status-dot {
            display: inline-block;
            width: 8px;
            height: 8px;
            background: #00ff88;
            border-radius: 50%;
            margin-right: 5px;
            box-shadow: 0 0 10px #00ff88;
        }
        .edit-link {
            color: var(--netflix-red);
            text-decoration: none;
            font-size: 0.9rem;
            font-weight: 600;
        }

        #qrcode img {
            border: 4px solid #fff;
        }

        .xs-small {
            font-size: 0.75rem;
        }

        .letter-spacing-1 {
            letter-spacing: 1px;
        }

        .fw-black {
            font-weight: 900;
        }

        .benefit-box {
            background: rgba(255,255,255,0.03);
            border: 1px dashed rgba(255,255,255,0.1);
            border-radius: 20px;
            padding: 20px;
        }
    </style>
}

@section Scripts {
    <script src="https://cdnjs.cloudflare.com/ajax/libs/qrcodejs/1.0.0/qrcode.min.js"></script>
    <script>
        document.addEventListener("DOMContentLoaded", function() {
            var userId = "@Model.MaNguoiDung";
            var userEmail = "@Model.Email";
            var qrText = "CINEZORE-MEMBER-" + userId + "-" + btoa(userEmail);
            
            new QRCode(document.getElementById("qrcode"), {
                text: qrText,
                width: 120,
                height: 120,
                colorDark : "#000000",
                colorLight : "#ffffff",
                correctLevel : QRCode.CorrectLevel.H
            });
        });
    </script>
}
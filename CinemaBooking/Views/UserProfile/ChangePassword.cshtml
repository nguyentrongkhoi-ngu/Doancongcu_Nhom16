@model CinemaBooking.Models.ViewModels.ChangePasswordViewModel

@{
    ViewData["Title"] = "Đổi mật khẩu";
}

<div class="profile-edit-wrapper" style="padding-top: 120px; min-height: 90vh; background: radial-gradient(circle at 90% 10%, rgba(229, 9, 20, 0.05) 0%, transparent 40%);">
    <div class="container pb-5">
        <!-- Breadcrumb / Header -->
        <div class="d-flex align-items-center mb-5 animate__animated animate__fadeIn">
            <a asp-action="Index" class="btn btn-outline-light btn-sm rounded-circle me-3" style="width: 40px; height: 40px; display: flex; align-items: center; justify-content: center;">
                <i class="fas fa-arrow-left"></i>
            </a>
            <div>
                <h2 class="text-white fw-black mb-0">Bảo mật tài khoản</h2>
                <p class="text-white-50 mb-0">Cập nhật mật khẩu của bạn để đảm bảo an toàn cho tài khoản</p>
            </div>
        </div>

        <div class="row g-4">
            <!-- Sidebar -->
            <div class="col-lg-4 animate__animated animate__fadeInLeft">
                <div class="glass-container p-4 h-100">
                    <div class="text-center">
                        <div class="security-icon-wrapper mx-auto mb-4">
                            <div class="security-icon-inner shadow-glow">
                                <i class="fas fa-shield-alt text-white" style="font-size: 3rem;"></i>
                            </div>
                        </div>
                        <h4 class="text-white fw-bold">Bảo mật</h4>
                        <p class="text-white-50 mb-4">@User.Identity.Name</p>
                        
                        <div class="nav flex-column gap-2 text-start">
                            <a asp-action="Index" class="nav-btn">
                                <i class="fas fa-th-large me-2"></i> Tổng quan
                            </a>
                            <a asp-action="Edit" class="nav-btn">
                                <i class="fas fa-user-edit me-2"></i> Chỉnh sửa thông tin
                            </a>
                            <a asp-action="ChangePassword" class="nav-btn active">
                                <i class="fas fa-key me-2"></i> Đổi mật khẩu
                            </a>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Main Form -->
            <div class="col-lg-8 animate__animated animate__fadeInRight">
                <div class="glass-container p-5 h-100">
                    <form asp-action="ChangePassword" method="post" class="modern-profile-form">
                        <div asp-validation-summary="ModelOnly" class="text-danger mb-4"></div>

                        <div class="row g-4">
                            <div class="col-md-12">
                                <label asp-for="CurrentPassword" class="form-label text-white-50 small text-uppercase fw-bold letter-spacing-1">Mật khẩu hiện tại</label>
                                <div class="input-group-cinematic">
                                    <i class="fas fa-lock icon"></i>
                                    <input asp-for="CurrentPassword" class="form-control" type="password" placeholder="Nhập mật khẩu hiện tại">
                                </div>
                                <span asp-validation-for="CurrentPassword" class="text-danger xs-small mt-1 d-block"></span>
                            </div>

                            <div class="col-12">
                                <hr class="border-secondary opacity-10 my-2">
                            </div>

                            <div class="col-md-12">
                                <label asp-for="NewPassword" class="form-label text-white-50 small text-uppercase fw-bold letter-spacing-1">Mật khẩu mới</label>
                                <div class="input-group-cinematic">
                                    <i class="fas fa-key icon"></i>
                                    <input asp-for="NewPassword" class="form-control" type="password" placeholder="Nhập mật khẩu mới">
                                </div>
                                <span asp-validation-for="NewPassword" class="text-danger xs-small mt-1 d-block"></span>
                            </div>

                            <div class="col-md-12">
                                <label asp-for="ConfirmPassword" class="form-label text-white-50 small text-uppercase fw-bold letter-spacing-1">Xác nhận mật khẩu</label>
                                <div class="input-group-cinematic">
                                    <i class="fas fa-check-double icon"></i>
                                    <input asp-for="ConfirmPassword" class="form-control" type="password" placeholder="Nhập lại mật khẩu mới">
                                </div>
                                <span asp-validation-for="ConfirmPassword" class="text-danger xs-small mt-1 d-block"></span>
                            </div>

                            <div class="col-12 mt-5">
                                <div class="d-flex gap-3 justify-content-end">
                                    <a asp-action="Index" class="btn btn-link text-white-50 text-decoration-none px-4">Hủy bỏ</a>
                                    <button type="submit" class="btn btn-netflix px-5 py-3 rounded-pill fw-bold">
                                        Cập nhật mật khẩu <i class="fas fa-sync-alt ms-2"></i>
                                    </button>
                                </div>
                            </div>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Styles {
    <style>
        .fw-black { font-weight: 900; }
        .letter-spacing-1 { letter-spacing: 1px; }
        .xs-small { font-size: 0.75rem; }

        .glass-container {
            background: rgba(255, 255, 255, 0.03);
            backdrop-filter: blur(15px);
            -webkit-backdrop-filter: blur(15px);
            border: 1px solid rgba(255, 255, 255, 0.1);
            border-radius: 24px;
        }

        .security-icon-wrapper {
            position: relative;
            width: 120px;
            height: 120px;
        }

        .security-icon-inner {
            width: 100%;
            height: 100%;
            border-radius: 50%;
            background: rgba(229, 9, 20, 0.1);
            border: 2px solid rgba(229, 9, 20, 0.3);
            display: flex;
            align-items: center;
            justify-content: center;
            transition: all 0.5s ease;
        }

        .shadow-glow {
            box-shadow: 0 0 30px rgba(229, 9, 20, 0.2);
        }

        .security-icon-wrapper:hover .security-icon-inner {
            transform: rotateY(180deg);
            background: rgba(229, 9, 20, 0.2);
            border-color: #e50914;
        }

        /* Sidebar Nav */
        .nav-btn {
            display: block;
            padding: 12px 20px;
            color: rgba(255,255,255,0.6);
            text-decoration: none;
            border-radius: 12px;
            transition: all 0.3s ease;
            font-weight: 500;
        }

        .nav-btn:hover {
            background: rgba(255,255,255,0.05);
            color: #fff;
            transform: translateX(5px);
        }

        .nav-btn.active {
            background: rgba(229, 9, 20, 0.1);
            color: #e50914;
            border-left: 3px solid #e50914;
        }

        /* Cinematic Inputs */
        .input-group-cinematic {
            position: relative;
            display: flex;
            align-items: center;
        }

        .input-group-cinematic .icon {
            position: absolute;
            left: 18px;
            color: rgba(255,255,255,0.3);
            font-size: 1.1rem;
            transition: color 0.3s ease;
        }

        .input-group-cinematic .form-control {
            background: rgba(255,255,255,0.05);
            border: 1px solid rgba(255,255,255,0.1);
            border-radius: 14px;
            color: #fff;
            padding: 14px 14px 14px 50px;
            transition: all 0.3s ease;
        }

        .input-group-cinematic .form-control:focus {
            background: rgba(255,255,255,0.08);
            border-color: #e50914;
            box-shadow: 0 0 15px rgba(229, 9, 20, 0.15);
        }

        .input-group-cinematic .form-control:focus + .icon {
            color: #e50914;
        }

        .btn-netflix {
            background: #e50914;
            color: #fff;
            border: none;
            transition: all 0.3s ease;
            box-shadow: 0 4px 15px rgba(229, 9, 20, 0.3);
        }

        .btn-netflix:hover {
            background: #f40612;
            transform: translateY(-2px);
            box-shadow: 0 6px 20px rgba(229, 9, 20, 0.4);
            color: #fff;
        }
    </style>
}

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
@model CinemaBooking.Models.ViewModels.ChangePasswordViewModel

@{
    ViewData["Title"] = "Đổi mật khẩu";
}

<div class="container" style="padding-top: 120px; min-height: 80vh;">
    <div class="row g-4">
        <!-- Sidebar Navigation -->
        <div class="col-lg-4">
            <div class="glass-panel p-4">
                <div class="text-center mb-4">
                    <div class="avatar-circle mx-auto mb-3" style="width: 100px; height: 100px; font-size: 2.5rem; background: var(--netflix-red);">
                        @User.Identity.Name?.Substring(0, 1).ToUpper()
                    </div>
                    <h4 class="text-white fw-bold mb-1">@User.Identity.Name</h4>
                </div>
                
                <hr class="border-secondary opacity-25">

                <nav class="nav flex-column profile-nav">
                    <a class="nav-link" asp-action="Index" asp-controller="UserProfile">
                        <i class="fas fa-user-circle me-2"></i> Hồ sơ cá nhân
                    </a>
                    <a class="nav-link" asp-action="Edit" asp-controller="UserProfile">
                        <i class="fas fa-user-edit me-2"></i> Chỉnh sửa thông tin
                    </a>
                    <a class="nav-link active" asp-action="ChangePassword" asp-controller="UserProfile">
                        <i class="fas fa-key me-2"></i> Đổi mật khẩu
                    </a>
                    <a class="nav-link" asp-action="LichSuDatVe" asp-controller="Home">
                        <i class="fas fa-history me-2"></i> Lịch sử đặt vé
                    </a>
                    <hr class="border-secondary opacity-25">
                    <a class="nav-link text-danger" asp-action="Logout" asp-controller="Account">
                        <i class="fas fa-sign-out-alt me-2"></i> Đăng xuất
                    </a>
                </nav>
            </div>
        </div>

        <!-- Main Content -->

                <form asp-action="ChangePassword" method="post" class="modern-form">
                    <div asp-validation-summary="ModelOnly" class="text-danger mb-4"></div>

                    <div class="form-floating mb-4 glassy-input-group">
                        <input asp-for="CurrentPassword" class="form-control glassy-input" placeholder="Mật khẩu hiện tại">
                        <label asp-for="CurrentPassword" class="text-white-50">Mật khẩu hiện tại</label>
                        <i class="fas fa-lock input-icon"></i>
                        <span asp-validation-for="CurrentPassword" class="text-danger small"></span>
                    </div>

                    <hr class="border-white-10 my-4">

                    <div class="form-floating mb-4 glassy-input-group">
                        <input asp-for="NewPassword" class="form-control glassy-input" placeholder="Mật khẩu mới">
                        <label asp-for="NewPassword" class="text-white-50">Mật khẩu mới</label>
                        <i class="fas fa-key input-icon"></i>
                        <span asp-validation-for="NewPassword" class="text-danger small"></span>
                    </div>

                    <div class="form-floating mb-5 glassy-input-group">
                        <input asp-for="ConfirmPassword" class="form-control glassy-input" placeholder="Xác nhận mật khẩu mới">
                        <label asp-for="ConfirmPassword" class="text-white-50">Xác nhận mật khẩu mới</label>
                        <i class="fas fa-check-double input-icon"></i>
                        <span asp-validation-for="ConfirmPassword" class="text-danger small"></span>
                    </div>

                    <div class="d-grid gap-3">
                        <button type="submit" class="btn btn-netflix py-3 rounded-pill fw-bold fs-5">
                            <i class="fas fa-sync-alt me-2"></i> Cập nhật mật khẩu
                        </button>
                        <a asp-action="Index" class="btn btn-link text-white-50 text-decoration-none py-2">
                            Quay lại Dashboard
                        </a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Styles {
    <style>
        .profile-nav .nav-link {
            color: rgba(255,255,255,0.7);
            padding: 12px 15px;
            border-radius: 4px;
            margin-bottom: 5px;
            transition: all 0.3s ease;
        }
        .profile-nav .nav-link:hover {
            background: rgba(255,255,255,0.05);
            color: #fff;
        }
        .profile-nav .nav-link.active {
            background: rgba(229, 9, 20, 0.1);
            color: var(--netflix-red);
            font-weight: bold;
        }
        
        .netflix-form .form-control {
            background: rgba(255,255,255,0.1);
            border: 1px solid rgba(255,255,255,0.1);
            color: #fff;
            padding: 12px 15px;
        }
        .netflix-form .form-control:focus {
            background: rgba(255,255,255,0.15);
            border-color: var(--netflix-red);
            box-shadow: none;
        }
    </style>
}

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}